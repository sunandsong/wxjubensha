/* 全局样式 —— 暗夜悬疑风 */
page {
  background: #1e1830;
  color: #ece8f5;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  min-height: 100vh;
}

.container {
  padding: 32rpx 28rpx 60rpx;
  box-sizing: border-box;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.subtitle {
  font-size: 26rpx;
  color: #b3a6cc;
  margin-top: 10rpx;
}

.card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 24rpx;
}

.btn {
  margin-top: 28rpx;
  background: linear-gradient(90deg, #7b5cff, #c44dff);
  color: #fff;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  padding: 32rpx 0;
  text-align: center;
  border: none;
}
.btn::after { border: none; }
.btn-ghost {
  background: transparent;
  border: 1rpx solid rgba(255,255,255,0.25);
  color: #d9d2ec;
}
/* 禁用态：淡化的紫色渐变（同一个按钮，只是暂时不可点）*/
.btn[disabled] {
  background: linear-gradient(90deg, #7b5cff, #c44dff) !important;
  color: #fff !important;
  border: none;
  opacity: 0.4;
}
.btn-ghost[disabled] {
  background: transparent !important;
  opacity: 0.4;
}

.muted { color: #9a8fb5; font-size: 26rpx; }
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(123,92,255,0.25);
  color: #cdbcff;
  margin-right: 12rpx;
}
.pre {
  white-space: pre-wrap;
  line-height: 1.7;
  font-size: 28rpx;
  color: #ddd6ee;
}

/* ── 全局特效 ── */
/* 页面入场：整页淡入（只在进入页面时触发一次）。
   注意：这里绝不能用 transform——动画保留的 transform 会让容器内所有 fixed 元素失效（退化成随内容排布） */
@keyframes pageIn { from { opacity: 0; } to { opacity: 1; } }
.container { animation: pageIn 0.4s ease both; }

/* 按钮点击反馈：按下时轻微缩放 */
.btn { transition: opacity 0.1s ease; }
.btn:active { opacity: 0.85; }
.btn-mini, .mini-btn, .gender-opt { transition: opacity 0.1s ease; }
.btn-mini:active, .mini-btn:active, .gender-opt:active { opacity: 0.8; }

/* 测试身份入口角标（仅开发/体验版）*/
.test-switch {
  position: fixed; left: 20rpx; bottom: 120rpx; z-index: 500;
  background: rgba(196,77,255,0.92); color: #fff;
  font-size: 24rpx; padding: 12rpx 24rpx; border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.4);
}
