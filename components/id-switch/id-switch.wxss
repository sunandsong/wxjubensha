.idsw {
  position: fixed; right: 12rpx; top: 18%; z-index: 999;
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  border-radius: 50%; font-size: 28rpx; font-weight: 700; color: #ffd9e5;
  background: rgba(30, 24, 48, 0.85); border: 1rpx solid rgba(255, 92, 138, 0.55);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}
.idsw:active { transform: scale(0.92); }

/* 自绘身份选择面板（showActionSheet 最多 6 项，不够用） */
.idsw-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  background: rgba(10, 6, 20, 0.75);
}
.idsw-panel {
  width: 60%; padding: 30rpx 0 14rpx; border-radius: 24rpx;
  background: #2a2140; border: 1rpx solid rgba(255, 255, 255, 0.12);
}
.idsw-title { text-align: center; font-size: 30rpx; font-weight: 700; color: #ece8f5; padding-bottom: 12rpx; }
.idsw-item {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  padding: 22rpx 0; font-size: 29rpx; color: #d9d2ec;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}
.idsw-item.on { color: #fff; font-weight: 600; }
.idsw-item:active { background: rgba(255, 255, 255, 0.06); }
.idsw-cur {
  font-size: 20rpx; color: #ffd9e5; padding: 2rpx 12rpx; border-radius: 999rpx;
  background: rgba(255, 92, 138, 0.25); border: 1rpx solid rgba(255, 92, 138, 0.5);
}
