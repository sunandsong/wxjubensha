.idsw {
  position: fixed; right: 12rpx; top: 18%; z-index: 999;
  width: 64rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  border-radius: 50%; font-size: 28rpx; font-weight: 700; color: #ffd9e5;
  background: rgba(30, 24, 48, 0.85); border: 1rpx solid rgba(255, 92, 138, 0.55);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}
.idsw:active { transform: scale(0.92); }
