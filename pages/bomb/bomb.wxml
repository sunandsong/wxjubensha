<view class="page {{booming ? 'quake' : ''}}">
  <!-- 爆炸白闪：生成瞬间闪一帧 -->
  <view class="flash {{booming ? 'on' : ''}}"></view>
  <!-- 氛围底图：警戒机库，云端图淡入；拿不到就纯色底 -->
  <image wx:if="{{bgUrl}}" class="scene-bg {{bgOk ? 'on' : ''}}" src="{{bgUrl}}" mode="aspectFill"
    bindload="onBgLoad" binderror="onBgErr"></image>

  <image wx:if="{{heroUrl}}" class="bomb-hero {{booming ? 'pump' : ''}}" src="{{heroUrl}}" mode="aspectFit" binderror="onHeroErr"></image>
  <view wx:else class="bomb-ico {{booming ? 'pump' : ''}}">💣</view>
  <view class="title">数字炸弹</view>
  <view class="rule">主持人点「生成」暗抽一颗 1~100 的炸弹数，群里轮流报数，报中的人爆炸 💥</view>

  <!-- 抽出的数 / 问号 / 爆炸中 -->
  <view class="num-box {{num ? 'lit' : ''}} {{booming ? 'shaking' : ''}}">
    <view wx:if="{{booming}}" class="num boom-emoji">💥</view>
    <view wx:elif="{{num}}" class="num pop">{{num}}</view>
    <view wx:else class="num">?</view>
    <view wx:if="{{num}}" class="meta">
      <view class="meta-ln">{{ts}}</view>
      <view class="meta-ln code">防伪码 {{code}}</view>
    </view>
  </view>

  <!-- 操作 -->
  <button class="gen-btn" bindtap="gen">{{num ? '重新生成' : '生成炸弹数'}}</button>
  <button wx:if="{{num}}" class="save-btn" bindtap="save" disabled="{{saving}}">保存为图片 🖼️</button>
  <view wx:if="{{num}}" class="tip">保存的图片带时间和防伪码，改图对不上号，赖不掉～</view>

  <!-- 离屏画布：留证图片在这里画 -->
  <canvas id="proof" type="2d" class="proof-canvas"></canvas>
</view>

<id-switch />
