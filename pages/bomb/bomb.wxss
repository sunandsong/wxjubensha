page { background: #2b2436; }
.page { padding: 60rpx 40rpx 80rpx; text-align: center; }

.bomb-ico { font-size: 120rpx; filter: drop-shadow(0 8rpx 20rpx rgba(255,120,60,0.35)); }
.title { margin-top: 10rpx; font-size: 44rpx; font-weight: 900; letter-spacing: 4rpx;
  background: linear-gradient(95deg, #fff, #ffce54, #ff7a45);
  -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent; }
.rule { margin: 18rpx auto 0; max-width: 560rpx; font-size: 24rpx; line-height: 1.7; color: #b9a7e6; }

/* 抽数展示区 */
.num-box { margin: 56rpx auto 0; width: 460rpx; padding: 56rpx 0 48rpx; border-radius: 40rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.14); }
.num-box.lit { background: rgba(255,206,84,0.08); border-color: rgba(255,206,84,0.35);
  box-shadow: 0 0 40rpx rgba(255,190,70,0.18); }
.num { font-size: 180rpx; font-weight: 900; line-height: 1; color: #ffce54;
  text-shadow: 0 6rpx 26rpx rgba(255,200,80,0.4); }
/* 爆炸动效：全屏地震 + 盒子猛晃 + 💥 炸开 + 数字弹出 */
.page.quake { animation: quake 0.62s ease; }
.num-box.shaking { animation: shake 0.62s ease; }
.boom-emoji { animation: burst 0.62s ease; }
.num.pop { animation: pop 0.35s cubic-bezier(0.2, 1.6, 0.4, 1); }
@keyframes quake {
  0%, 100% { transform: translate(0, 0); }
  12% { transform: translate(-24rpx, 10rpx); }
  25% { transform: translate(22rpx, -12rpx); }
  38% { transform: translate(-18rpx, -8rpx); }
  52% { transform: translate(16rpx, 10rpx); }
  66% { transform: translate(-12rpx, 6rpx); }
  80% { transform: translate(8rpx, -4rpx); }
  92% { transform: translate(-4rpx, 2rpx); }
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  15% { transform: translateX(-28rpx) rotate(-3deg); }
  30% { transform: translateX(24rpx) rotate(3deg); }
  45% { transform: translateX(-20rpx) rotate(-2deg); }
  60% { transform: translateX(16rpx) rotate(1.5deg); }
  75% { transform: translateX(-10rpx); }
  90% { transform: translateX(6rpx); }
}
@keyframes burst {
  0% { transform: scale(0.3); opacity: 0.4; }
  40% { transform: scale(1.35); opacity: 1; }
  100% { transform: scale(1); }
}
@keyframes pop {
  0% { transform: scale(0.2); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
.meta { margin-top: 26rpx; }
.meta-ln { font-size: 22rpx; color: rgba(255,255,255,0.6); line-height: 1.8; }
.meta-ln.code { color: #8be0c9; font-weight: 700; letter-spacing: 2rpx; }

/* 按钮 */
.gen-btn { margin: 56rpx auto 0; width: 480rpx; height: 100rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 999rpx; font-size: 32rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #ff7a45, #ff4d6a); box-shadow: 0 8rpx 22rpx rgba(255,100,70,0.4); }
.gen-btn::after { border: none; }
.save-btn { margin: 26rpx auto 0; width: 480rpx; height: 100rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 999rpx; font-size: 32rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #8b5cff, #c44dff); box-shadow: 0 8rpx 22rpx rgba(150,80,255,0.45); }
.save-btn::after { border: none; }
.save-btn[disabled] { opacity: 0.6; color: #fff; }
.tip { margin-top: 24rpx; font-size: 22rpx; color: rgba(255,255,255,0.45); }

/* 离屏画布：移出可视区，仅用于绘制留证图 */
.proof-canvas { position: fixed; left: -9999rpx; top: 0; width: 750px; height: 1000px; }
