<view wx:if="{{testTag}}" class="test-switch" bindtap="gotoTest">切换身份·{{testTag}}</view>

<view class="container">
  <!-- ============ 剧情阶段（逐幕推进）============ -->
  <block wx:if="{{status==='playing'}}">
    <!-- 主持人：本幕剧情（第一幕已把世界观接在前面），合成一整块故事 -->
    <view wx:if="{{isHost}}" class="card act-card">
      <view class="pre">{{actHostStory || actNarration}}</view>
    </view>

    <!-- 玩家：你这一幕的故事（第一人称）-->
    <view wx:if="{{myChar && myActStory}}" class="card mychar">
      <view class="act-title">{{actLabel}}</view>
      <view class="pre">{{myActStory}}</view>
    </view>

    <!-- 主持人流程提示 -->
    <view class="card mychar host-guide" wx:if="{{isHost}}">
      <view class="muted">你是主持人 · 不参与角色</view>
      <!-- 本子自带群活动清单（咖啡馆）：逐条带流程 -->
      <block wx:if="{{actHostActivities.length}}">
        <view class="field-label">🎬 本幕群活动</view>
        <view class="guide-foot" wx:for="{{actHostActivities}}" wx:key="*this">{{item}}</view>
      </block>
      <!-- 通用流程提示（其它本子） -->
      <block wx:else>
        <view class="guide-foot" wx:if="{{actNum===1}}">让大家轮流自我介绍（说角色名+公开身份）→ 每人读本幕私密剧情 → 念出本幕线索 → 每人轮流发言一次 → 点底部进入下一幕。</view>
        <view class="guide-foot" wx:elif="{{!isLastAct}}">每人读本幕私密剧情 → 念出本幕新线索 → 每人针对线索发言一次、互相提问 → 点底部进入下一幕。</view>
        <view class="guide-foot" wx:else>每人读本幕私密剧情 → 念出本幕新线索 → 每人做最后陈述 → 点底部进入投票。</view>
        <view wx:if="{{actHostPrompts.length}}" class="host-prompts">
          <view class="field-label">💬 冷场时，挑一句直接问</view>
          <view class="ask-item" wx:for="{{actHostPrompts}}" wx:key="*this">{{item}}</view>
        </view>
      </block>
      <button class="btn btn-ghost end-inline" bindtap="endGame">结束游戏</button>
    </view>

    <!-- 本幕线索：随幕自动公开，但只发给主持人；主持人保存/截图后发到微信群（autoClues 本子）-->
    <view class="card" wx:if="{{autoClues && clues.length && isHost}}">
      <view class="row-between">
        <view class="sec-title">🔎 本幕线索（仅主持人可见）</view>
        <text class="muted">截图发到群里</text>
      </view>
      <view class="muted tip">玩家端只有自己的剧情，看不到线索。有图的长按「保存 / 发送到群」；暂无图的先截图整张卡片发群。</view>
      <view class="clue-grid">
        <view class="clue open" wx:for="{{clues}}" wx:key="id">
          <image wx:if="{{item.img}}" class="clue-img" src="{{item.img}}" mode="widthFix" show-menu-by-longpress></image>
          <view class="clue-icon">{{item.icon}}</view>
          <view class="clue-name">{{item.name}}</view>
          <view class="clue-text">{{item.text}}</view>
        </view>
      </view>
    </view>

    <!-- 搜证区：本幕的搜查点（非 autoClues 本子）-->
    <view class="card" wx:if="{{spots.length}}">
      <view class="row-between">
        <view class="sec-title">🔍 搜证 · 本幕搜查点</view>
        <text wx:if="{{!isHost}}" class="muted">剩余 {{searchLeft}}/{{searchLimit}} 次</text>
        <text wx:else class="muted">主持人可见全部</text>
      </view>
      <view class="muted tip" wx:if="{{!isHost}}">每幕限搜 {{searchLimit}} 处，搜到的线索只有你自己看到——其余靠大家在群里交换。</view>
      <view class="clue-grid">
        <view class="clue {{item.reveal ? (item.empty ? 'searched-empty' : 'open') : ''}}" wx:for="{{spots}}" wx:key="id">
          <view class="clue-icon">{{item.empty && item.reveal ? '🚫' : item.icon}}</view>
          <!-- 已搜 / 主持人：显示结果（线索 或 一无所获）-->
          <block wx:if="{{item.reveal}}">
            <view class="muted small">{{item.place}}</view>
            <view class="clue-name">{{item.name}}</view>
            <view class="clue-text">{{item.text}}</view>
          </block>
          <!-- 未搜：只显示地点 + 搜查 -->
          <block wx:else>
            <view class="clue-name">{{item.place}}</view>
            <view wx:if="{{searchLeft>0}}" class="search-btn" data-id="{{item.id}}" bindtap="search">搜查这里</view>
            <view wx:else class="muted small">本幕已搜完</view>
          </block>
          <!-- 谁搜过（公开）-->
          <view wx:if="{{item.searchedCount}}" class="searchers">已搜：{{item.searchedBy}}</view>
        </view>
      </view>
    </view>

    <!-- 我的线索本：我亲自搜到的，跨幕累积，仅我可见 -->
    <view class="card" wx:if="{{myClues.length}}">
      <view class="sec-title">🗂 我的线索本（仅你可见）</view>
      <view class="clue-grid">
        <view class="clue open" wx:for="{{myClues}}" wx:key="id">
          <view class="clue-icon">{{item.icon}}</view>
          <view class="clue-name">{{item.name}}</view>
          <view class="clue-text">{{item.text}}</view>
        </view>
      </view>
    </view>

  </block>

  <!-- ============ 投票阶段 ============ -->
  <block wx:if="{{status==='voting'}}">
    <view class="card">
      <view class="sec-title">指认凶手</view>
      <view wx:if="{{isHost}}" class="guide-foot">让每人说出怀疑对象和理由 → 各自点选真凶 → 已投 {{votedCount}}/{{totalPlayers}}，投满后点底部公布真相。主持人不投票。</view>
      <view wx:else class="muted">回群里讨论后再投。已投票 {{votedCount}}/{{totalPlayers}}，选定你认为的真凶，可改票。</view>
    </view>
    <view class="vote-list" wx:if="{{!isHost}}">
      <view class="vote-item {{myVote===item.id?'picked':''}}" wx:for="{{roster}}" wx:key="id" data-id="{{item.id}}" bindtap="vote">
        <view class="vname">{{item.name}}<text class="vtitle">{{item.title}}</text></view>
        <view class="vcheck" wx:if="{{myVote===item.id}}">✓ 已选</view>
      </view>
    </view>
  </block>

  <!-- 主持人控制（固定底部）-->
  <view class="host-ctrl" wx:if="{{isHost}}">
    <button wx:if="{{status==='playing' && !isLastAct}}" class="btn" bindtap="advance">进入下一幕（第{{actNum+1}}幕）</button>
    <button wx:if="{{status==='playing' && isLastAct}}" class="btn" bindtap="advance">本幕结束，进入投票</button>
    <button wx:if="{{status==='voting'}}" class="btn" bindtap="advance">公布真相</button>
  </view>
</view>
