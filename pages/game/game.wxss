/* 剧情重点句高亮 */
.pre .hl { color: #ffd9a8; font-weight: 600; background: rgba(255,217,168,0.12); border-radius: 4rpx; padding: 0 4rpx; }

.tab-bar { display: flex; gap: 12rpx; margin-bottom: 8rpx; }
.tab {
  flex: 1; text-align: center; font-size: 26rpx; color: #8a809e;
  padding: 16rpx 0; border-radius: 14rpx; background: rgba(255,255,255,0.04);
}
.tab.on { color: #fff; background: linear-gradient(90deg, #7b5cff, #c44dff); font-weight: 600; }

.sec-title { font-size: 32rpx; font-weight: 700; margin-bottom: 14rpx; }
.tip { margin-top: 16rpx; display: block; }

.act-card { border: 1rpx solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); }
.act-title { font-size: 36rpx; font-weight: 700; margin-bottom: 14rpx; color: #ffd9a8; }

.act-secret {
  margin-top: 20rpx; padding-top: 20rpx;
  border-top: 1rpx dashed rgba(255,255,255,0.15);
}
.secret-label { font-size: 24rpx; color: #c44dff; font-weight: 600; margin-bottom: 12rpx; }
.end-inline { margin-top: 24rpx; }

.mychar { border: 1rpx solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); }
/* 玩家第一幕：自己的角色照片 */
.char-photo { width: 70%; max-width: 420rpx; border-radius: 18rpx; display: block; margin: 8rpx auto 12rpx; }
.char-caption { text-align: center; font-size: 24rpx; color: #b3a6cc; margin-bottom: 14rpx; }
.char-actions { justify-content: center; margin-bottom: 18rpx; }

/* 主持人流程提示 */
.guide-foot { margin-top: 12rpx; display: block; font-size: 27rpx; line-height: 1.55; color: #ddd6ee; }
.char-name { font-size: 38rpx; font-weight: 700; margin: 8rpx 0 16rpx; }
.objective { margin-top: 20rpx; font-size: 28rpx; color: #ffd9a8; line-height: 1.6; }
.obj-label { color: #ffb347; font-weight: 600; }

.field-label { color: #c44dff; font-weight: 600; }
.persona { margin-top: 16rpx; font-size: 27rpx; line-height: 1.6; color: #ddd6ee; }
.timeline { margin-top: 20rpx; }
.tl-item {
  position: relative; margin-top: 12rpx; padding-left: 26rpx;
  font-size: 26rpx; line-height: 1.55; color: #ddd6ee;
}
.tl-item::before {
  content: ''; position: absolute; left: 4rpx; top: 14rpx;
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #c44dff;
}

/* 世界观折叠卡片 */
.row-between { display: flex; align-items: center; justify-content: space-between; }
.world-text { margin-top: 16rpx; }

/* 小秘密 */
.secret-box {
  margin-top: 20rpx; padding: 20rpx;
  border: 1rpx dashed rgba(255,255,255,0.2); border-radius: 16rpx;
  background: rgba(255,255,255,0.04);
}
.secret-body { margin-top: 12rpx; }

/* 盘问任务 / 主持人追问钩子 */
.asks, .host-prompts { margin-top: 20rpx; }
.ask-item {
  margin-top: 12rpx; padding: 16rpx 20rpx;
  font-size: 26rpx; line-height: 1.5; color: #ddd6ee;
  background: rgba(255,255,255,0.05); border-radius: 14rpx;
}
.host-prompts { padding-top: 20rpx; border-top: 1rpx dashed rgba(255,255,255,0.15); }

/* 本幕任务 */
.task-item {
  margin-top: 12rpx; padding-left: 8rpx;
  font-size: 27rpx; line-height: 1.55; color: #ddd6ee;
}
.task-btn {
  margin-top: 20rpx; padding: 22rpx 0; text-align: center;
  background: linear-gradient(90deg, #7b5cff, #c44dff); color: #fff;
  font-size: 30rpx; font-weight: 600; border-radius: 16rpx;
}
.task-done {
  margin-top: 20rpx; padding: 22rpx 0; text-align: center;
  background: rgba(123,92,255,0.12); color: #b7a6ff;
  font-size: 28rpx; border-radius: 16rpx;
}
.task-progress {
  margin-top: 20rpx; font-size: 26rpx; color: #ffb347;
}
.task-progress.ok { color: #7fe0a8; }
/* 等待中的推进按钮：置灰提示尚未全员完成（仍可点强行推进）*/
.btn-wait { background: #3a3450; color: #b3a6cc; }

/* 关系网 */
.rel-item {
  margin-top: 14rpx; padding-left: 26rpx; position: relative;
  font-size: 26rpx; line-height: 1.55; color: #ddd6ee;
}
.rel-item::before {
  content: '·'; position: absolute; left: 8rpx; top: -2rpx;
  color: #c44dff; font-weight: 700;
}

.roster { display: flex; flex-direction: column; gap: 14rpx; }
.rmember { display: flex; align-items: center; gap: 14rpx; flex-wrap: wrap; }
.ravatar { width: 48rpx; height: 48rpx; border-radius: 50%; display: block; }
.rplayer { font-size: 24rpx; color: #b3a6cc; }
.rname { font-size: 30rpx; font-weight: 600; }
.rtitle { font-size: 24rpx; color: #b3a6cc; }
.rme { font-size: 22rpx; color: #c44dff; }
.rnpc { font-size: 20rpx; color: #ffb347; border: 1rpx solid rgba(255,179,71,0.5); border-radius: 999rpx; padding: 2rpx 12rpx; }

.clue-grid { display: flex; flex-wrap: wrap; gap: 20rpx; margin-top: 20rpx; }
.clue {
  width: calc(50% - 10rpx); box-sizing: border-box; min-height: 200rpx;
  background: rgba(255,255,255,0.05); border: 1rpx dashed rgba(255,255,255,0.2);
  border-radius: 20rpx; padding: 24rpx; text-align: center;
}
.clue.open { border-style: solid; border-color: rgba(255,255,255,0.18); background: rgba(255,255,255,0.06); text-align: left; }
.clue.searched-empty { border-style: solid; border-color: rgba(255,255,255,0.1); background: rgba(255,255,255,0.02); text-align: left; opacity: 0.6; }
.clue-img { width: 100%; border-radius: 14rpx; margin-bottom: 12rpx; display: block; }
.clue-icon { font-size: 48rpx; }
.clue-name { font-size: 28rpx; font-weight: 600; margin-top: 10rpx; }
.clue-text { font-size: 24rpx; line-height: 1.5; margin-top: 10rpx; color: #ddd6ee; }

/* 主持人：复制行（提示/问题）+ 小按钮 */
.copy-row {
  display: flex; align-items: flex-start; gap: 12rpx;
  margin-top: 14rpx; font-size: 27rpx; line-height: 1.55; color: #ddd6ee;
}
.copy-text { flex: 1; }
.mini-btn {
  flex: none; align-self: flex-start; line-height: 1.7;
  background: rgba(123,92,255,0.3); color: #ddd2ff;
  font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 999rpx;
}

/* 主持人线索：整宽列表（图 + 文字 + 复制/下载）*/
.clue-list { display: flex; flex-direction: column; gap: 22rpx; margin-top: 16rpx; }
.clue-card {
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 18rpx; padding: 22rpx 24rpx;
}
.clue-card .clue-name { font-size: 29rpx; font-weight: 600; margin-top: 0; }
.clue-card .clue-text { font-size: 25rpx; line-height: 1.55; margin-top: 8rpx; color: #ddd6ee; }
.clue-actions { display: flex; gap: 16rpx; margin-top: 18rpx; }
.cast-title { font-size: 24rpx; color: #b3a6cc; font-weight: 400; }
/* 离屏 canvas：渲染平面图用，移出屏幕不显示 */
.offscreen-canvas { position: fixed; left: -9999rpx; top: 0; width: 720px; height: 900px; }

/* 搜证 */
.search-btn {
  margin-top: 16rpx; padding: 12rpx 0;
  color: #c4a8ff; text-align: center; font-size: 26rpx;
}
.small { font-size: 22rpx; margin-top: 16rpx; }
.searchers {
  margin-top: 14rpx; font-size: 20rpx; color: #ffb347;
  border-top: 1rpx dashed rgba(255,255,255,0.12); padding-top: 10rpx;
}

.vote-list { margin-top: 20rpx; display: flex; flex-direction: column; gap: 16rpx; }
.vote-item {
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 18rpx; padding: 26rpx 28rpx;
}
.vote-item.picked { border-color: #c44dff; background: rgba(196,77,255,0.18); }
.vname { font-size: 32rpx; font-weight: 600; }
.vtitle { font-size: 24rpx; color: #b3a6cc; margin-left: 14rpx; font-weight: 400; }
.vcheck { color: #c44dff; font-size: 28rpx; font-weight: 600; }

/* 房主控制 / 退出：不悬浮，跟在内容最后（页面最下面） */
.host-ctrl, .center {
  padding: 24rpx 0 calc(10rpx + env(safe-area-inset-bottom));
}
.host-ctrl .btn { margin-top: 0; }
.host-ctrl .btn-ghost { background: #221b36; }
/* 玩家「退出房间」（host-ctrl 直接子按钮）整宽 */
.host-ctrl > .btn { width: 100% !important; box-sizing: border-box; }
.ctrl-row { display: flex; gap: 18rpx; }
.ctrl-row .btn { flex: 1; }
.ctrl-row .end-btn { flex: 0 0 200rpx; }
.center { text-align: center; }

/* 分幕切换过场层 */
.act-transition {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 999;
  display: flex; align-items: center; justify-content: center;
  background: rgba(18,14,28,0.97);
  opacity: 0; pointer-events: none; transition: opacity 0.45s ease;
}
.act-transition.show { opacity: 1; }
.at-inner { text-align: center; transform: translateY(20rpx); opacity: 0; transition: all 0.5s ease 0.1s; }
.act-transition.show .at-inner { transform: translateY(0); opacity: 1; }
.at-label { font-size: 64rpx; font-weight: 700; color: #ffd9a8; letter-spacing: 6rpx; }
.at-title { margin-top: 18rpx; font-size: 34rpx; color: #ddd6ee; letter-spacing: 4rpx; }

/* ══ 光影·一根线 ══ */
page { background: #17121f; }
.fx-dust { position: fixed; left: -30vw; top: -30vh; width: 160vw; height: 160vh; z-index: 0;
  opacity: 0.045; mix-blend-mode: screen; pointer-events: none; filter: blur(2rpx); }
.card, .vote-list { position: relative; z-index: 1; }
/* 注意：.host-ctrl 必须保持上方定义的 position: fixed（钉在屏幕底部），不能在这里覆盖成 relative */
/* 我的剧情卡 = 全屏唯一被照亮的区域(外部压暗)。突出质感对齐海龟汤汤面卡 */
.mychar:not(.host-guide) {
  border-radius: 36rpx !important;
  padding: 34rpx 32rpx 38rpx !important;
  background: linear-gradient(170deg, #473a7d, #332a58) !important;
  border: 3rpx solid rgba(202,189,255,0.7) !important;
  box-shadow: 0 0 0 9999rpx rgba(6,3,14,0.5), 0 0 56rpx rgba(165,139,255,0.28),
    0 18rpx 52rpx rgba(0,0,0,0.5), inset 0 2rpx 0 rgba(255,255,255,0.14);
  position: relative; z-index: 1; }
/* 剧情正文加大加松，读起来更突出（对齐海龟汤 sc-story）*/
.mychar:not(.host-guide) .pre { font-size: 34rpx; line-height: 1.95; color: #fff; }
.mychar:not(.host-guide) .act-title { font-size: 30rpx; }

/* 主持人「发群内容」卡：同款海龟汤突出质感（这是主持人的核心操作面） */
.act-card {
  border-radius: 36rpx !important;
  padding: 30rpx 32rpx 34rpx !important;
  background: linear-gradient(170deg, #473a7d, #332a58) !important;
  border: 3rpx solid rgba(202,189,255,0.7) !important;
  box-shadow: 0 0 56rpx rgba(165,139,255,0.28), 0 18rpx 52rpx rgba(0,0,0,0.5),
    inset 0 2rpx 0 rgba(255,255,255,0.14) !important; }
.act-card .sec-title { font-size: 34rpx; font-weight: 700; }
.act-card .pre { font-size: 34rpx; line-height: 1.9; color: #fff; margin-top: 14rpx; }
/* 渐变卡上的「一键复制全部」按钮更亮一点 */
.act-card .mini-btn { background: rgba(255,255,255,0.9); color: #3a2d6b; font-weight: 700; }
/* 主持人的流程提示卡也挂了 mychar,还原为普通暗卡,别抢光 */
.host-guide { box-shadow: none !important; background: rgba(255,255,255,0.06) !important;
  border: 1rpx solid rgba(255,255,255,0.1) !important; }
/* 关键句：保持黄色加粗高亮（见文件顶部 .pre .hl 基础样式） */
/* 幕间过场:黑幕 + 体积光束打下 + 白字辉光 + 线划底 */
.act-transition { background: rgba(7,4,14,0.97) !important; }
.at-beam { position: absolute; top: -4%; left: 50%; transform: translateX(-50%);
  width: 78vw; height: 72vh; mix-blend-mode: screen; opacity: 0.9; }
.at-label { letter-spacing: 10rpx !important; color: #b8a8e0 !important; }
.at-title { color: #fff !important; text-shadow: 0 0 34rpx rgba(165,139,255,0.7); }
.at-inner::after { content: ""; display: block; width: 220rpx; height: 2rpx; margin: 22rpx auto 0;
  background: linear-gradient(90deg, transparent, #e8e0ff, transparent); box-shadow: 0 0 12rpx rgba(165,139,255,0.7); }
/* 投票:光聚到所选,其余沉入暗处 */
.vote-item { transition: all 0.3s; }
.vote-item.picked { background: #2a2248 !important; border-color: rgba(232,224,255,0.85) !important;
  box-shadow: 0 0 28rpx rgba(202,189,255,0.35); }
.vote-item.dim { opacity: 0.35; filter: saturate(0.4); }
