<view class="home">
  <!-- 全屏夜幕背景图：缩略图秒显垫底，云图加载完淡入；随陀螺仪反向微动(视差远景) -->
  <image class="pagebg pagebg-th" src="{{bgTh}}" mode="widthFix" style="transform:{{bgShift}}"></image>
  <image class="pagebg hd {{bgOk ? 'on' : ''}}" src="{{bg}}" mode="widthFix" bindload="onBgLoad" style="transform:{{bgShift}}"></image>
  <view class="pagebg-fade"></view>
  <view class="bokeh"></view>

  <!-- 测试身份入口（仅开发/体验版可见） -->
  <view wx:if="{{testTag}}" class="test-switch" bindtap="gotoTest">切换身份·{{testTag}}</view>
  <view wx:elif="{{isDev}}" class="test-switch" bindtap="gotoTest">测试身份</view>

  <!-- 用户信息条：头像在左 -->
  <view class="userbar">
    <view class="ub-av" bindtap="goMe">
      <image wx:if="{{avatar}}" class="ub-img" src="{{avatar}}" mode="aspectFill" />
      <view wx:else class="ub-img ub-ph">🐱</view>
    </view>
    <view class="ub-hi">Hi，{{nick}} <text class="ub-wave">👋</text></view>
  </view>

  <!-- 剧本杀 · 招牌大横幅 -->
  <view class="hero" bindtap="goScripts">
    <!-- 立绘随陀螺仪正向微动(视差近景)，与背景反向 → 裸眼3D纵深 -->
    <view class="hero-man-wrap" style="transform:{{manShift}}">
      <image class="hero-man" src="{{heroManTh}}" mode="aspectFit"></image>
      <image class="hero-man hd {{heroOk ? 'on' : ''}}" src="{{heroMan}}" mode="aspectFit" bindload="onHeroLoad"></image>
    </view>
    <view class="hero-body">
      <view class="hero-logo">夜幕降临</view>
      <view class="hero-logo">推理开始</view>
      <view class="hero-sub">谁是隐藏在黑暗中的真相？</view>
      <view class="hero-join">快速加入 ›</view>
    </view>
  </view>

  <!-- 4 个派对游戏 2×2 -->
  <view class="cards">
    <view class="gcard" wx:for="{{games}}" wx:key="id" data-game="{{item.id}}" bindtap="goGame" style="--ac:{{item.c}}">
      <image class="gc-pic-blur" src="{{item.th}}" mode="aspectFill"></image>
      <image class="gc-pic gc-pic-th" src="{{item.th}}" mode="aspectFill"></image>
      <image class="gc-pic hd {{item.ok ? 'on' : ''}}" src="{{item.img}}" mode="aspectFill" bindload="onCardLoad" data-i="{{index}}"></image>
      <view class="gc-scrim"></view>
      <view class="gc-head"><text class="gc-ico">{{item.ico}}</text><text class="gc-name">{{item.name}}</text></view>
      <view class="gc-foot">
        <view class="gc-count">{{item.d1}}，{{item.d2}}</view>
        <view class="gc-go">›</view>
      </view>
    </view>
  </view>

  <!-- 悬浮圆钮：回房间 / 快速进房（可拖动，位置记忆） -->
  <view class="fab {{fabRoom ? 'fab-back' : ''}}" style="left:{{fabX}}px; top:{{fabY}}px;"
    catchtouchstart="onFabStart" catchtouchmove="onFabMove" catchtouchend="onFabDrop" catchtouchcancel="onFabDrop">
    {{fabRoom ? '↩' : '＋'}}
  </view>

  <!-- 快速进房弹框 -->
  <view class="jmask" wx:if="{{showQuickJoin}}" bindtap="hideQuickJoin">
    <view class="jmodal" catchtap="">
      <view class="j-title">进入房间</view>
      <input class="j-input" type="number" maxlength="4" placeholder="4 位房间号"
        value="{{quickCode}}" bindinput="onQuickInput" focus="{{showQuickJoin}}" />
      <view class="j-tip">输满 4 位自动进入 · 卧底/剧本杀房间都可以</view>
      <button class="j-cancel" bindtap="hideQuickJoin">取消</button>
    </view>
  </view>

</view>

<id-switch />
