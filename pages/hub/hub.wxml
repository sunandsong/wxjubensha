<view class="home">
  <!-- 全屏夜幕背景图：缩略图秒显垫底，云图加载完淡入；随陀螺仪反向微动(视差远景) -->
  <image class="pagebg pagebg-th" src="{{bgTh}}" mode="widthFix" style="transform:{{bgShift}}"></image>
  <image class="pagebg hd {{bgOk ? 'on' : ''}}" src="{{bg}}" mode="widthFix" bindload="onBgLoad" binderror="onBgErr" style="transform:{{bgShift}}"></image>
  <view class="pagebg-fade"></view>
  <view class="bokeh"></view>

  <!-- 用户信息条：头像在左 -->
  <view class="userbar">
    <view class="ub-av" bindtap="goMe">
      <image wx:if="{{avatar}}" class="ub-img" src="{{avatar}}" mode="aspectFill" />
      <view wx:else class="ub-img ub-ph">🐱</view>
    </view>
    <view class="ub-hi">Hi，{{nick}} <text class="ub-wave">👋</text></view>
  </view>

  <!-- 剧本杀 · 招牌大横幅 -->
  <view class="hero" bindtap="goScripts">
    <!-- 立绘随陀螺仪正向微动(视差近景)，与背景反向 → 裸眼3D纵深 -->
    <view class="hero-man-wrap" style="transform:{{manShift}}">
      <image class="hero-man" src="{{heroManTh}}" mode="aspectFit"></image>
      <image class="hero-man hd {{heroOk ? 'on' : ''}}" src="{{heroMan}}" mode="aspectFit" bindload="onHeroLoad" binderror="onHeroErr"></image>
    </view>
    <view class="hero-body">
      <view class="hero-logo">夜幕降临</view>
      <view class="hero-logo">推理开始</view>
      <view class="hero-sub">谁是隐藏在黑暗中的真相？</view>
      <view class="hero-join">快速加入 ›</view>
    </view>
  </view>

  <!-- 4 个派对游戏 2×2 -->
  <view class="cards">
    <view class="gcard" wx:for="{{games}}" wx:key="id" data-game="{{item.id}}" bindtap="goGame" style="--ac:{{item.c}}">
      <image class="gc-pic-blur" src="{{item.th}}" mode="aspectFill"></image>
      <image class="gc-pic gc-pic-th" src="{{item.th}}" mode="aspectFill"></image>
      <image class="gc-pic hd {{item.ok ? 'on' : ''}}" src="{{item.img}}" mode="aspectFill" bindload="onCardLoad" binderror="onCardErr" data-i="{{index}}"></image>
      <view class="gc-scrim"></view>
      <view class="gc-head"><text class="gc-ico">{{item.ico}}</text><text class="gc-name">{{item.name}}</text></view>
      <view class="gc-foot">
        <view class="gc-count">{{item.d1}}，{{item.d2}}</view>
        <view class="gc-go">›</view>
      </view>
    </view>
  </view>

  <!-- 悬浮圆钮：回房间 / 快速进房（可拖动，位置记忆） -->
  <view class="fab {{fabRoom ? 'fab-back' : ''}}" style="left:{{fabX}}px; top:{{fabY}}px;"
    catchtouchstart="onFabStart" catchtouchmove="onFabMove" catchtouchend="onFabDrop" catchtouchcancel="onFabDrop">
    {{fabRoom ? '↩' : '＋'}}
  </view>

  <!-- 快速进房弹框 -->
  <view class="jmask" wx:if="{{showQuickJoin}}" bindtap="hideQuickJoin">
    <view class="jmodal" catchtap="">
      <view class="j-title">进入房间</view>
      <input class="j-input" type="number" maxlength="4" placeholder="4 位房间号"
        value="{{quickCode}}" bindinput="onQuickInput" focus="{{showQuickJoin}}" />
      <view class="j-tip">输满 4 位自动进入 · 卧底/剧本杀房间都可以</view>
      <button class="j-cancel" bindtap="hideQuickJoin">取消</button>
    </view>
  </view>

  <!-- 强制登录门：头像 → 昵称 → 性别（填全才能进） -->
  <view class="login-mask" wx:if="{{needLogin}}" catchtouchmove="noop">
    <view class="login-card">
      <view class="login-brand">群本杀</view>
      <view class="login-steps">{{loginStep}} / 3</view>

      <block wx:if="{{loginStep === 1}}">
        <view class="login-title">第一步 · 选择头像</view>
        <view class="login-sub">点下方用你的微信头像</view>
        <button class="login-avatar" open-type="chooseAvatar" bind:chooseavatar="onLoginAvatar">
          <image wx:if="{{loginAvatar}}" class="la-img" src="{{loginAvatar}}" mode="aspectFill" />
          <view wx:else class="la-ph">＋ 头像</view>
        </button>
        <button class="login-btn" bindtap="loginNext" disabled="{{loginUploading || !loginAvatar}}">{{loginUploading ? '头像上传中…' : '下一步'}}</button>
      </block>

      <block wx:elif="{{loginStep === 2}}">
        <view class="login-title">第二步 · 填写昵称</view>
        <view class="login-sub">点输入框，微信会带出你的昵称</view>
        <input class="login-input" type="nickname" placeholder="点这里填写昵称" placeholder-class="login-ph"
          value="{{loginNick}}" bindinput="onLoginNick" bindblur="onLoginNick" maxlength="8" />
        <view class="login-row">
          <button class="login-btn ghost" bindtap="loginBack">上一步</button>
          <button class="login-btn" bindtap="loginNext" disabled="{{!loginNick}}">下一步</button>
        </view>
      </block>

      <block wx:else>
        <view class="login-title">第三步 · 选择性别</view>
        <view class="login-sub">决定你在剧本里的角色形象</view>
        <view class="login-gender">
          <view class="lg-opt {{loginGender === 'm' ? 'on' : ''}}" data-g="m" bindtap="pickLoginGender">♂ 男生</view>
          <view class="lg-opt {{loginGender === 'f' ? 'on' : ''}}" data-g="f" bindtap="pickLoginGender">♀ 女生</view>
        </view>
        <view class="login-row">
          <button class="login-btn ghost" bindtap="loginBack">上一步</button>
          <button class="login-btn" bindtap="loginDone" disabled="{{!loginGender}}">进入游戏</button>
        </view>
      </block>
    </view>
  </view>

</view>

<id-switch />
