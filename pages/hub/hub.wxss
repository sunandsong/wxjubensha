page { background: #2b2436; }
.home { position: relative; min-height: 100vh; padding: 24rpx 16rpx 40rpx; box-sizing: border-box; overflow: hidden; }

/* 全屏夜幕背景图 + 向下渐隐（融进 #201f3b）*/
.pagebg { position: fixed; top: -10rpx; left: -10rpx; width: calc(100% + 20rpx); z-index: 0;
  filter: brightness(0.6); transition: transform 0.1s linear; }
/* 缩略图垫底：模糊只为掩住像素感（云图加载完即被盖住） */
.pagebg-th { filter: blur(24rpx) brightness(0.6); }
/* 云图层：加载完成后淡入盖过缩略图 */
.hd { opacity: 0; transition: opacity 0.35s ease, transform 0.1s linear; }
.hd.on { opacity: 1; }
.pagebg-fade {
  position: fixed; top: 0; left: 0; right: 0; height: 460rpx; z-index: 0; pointer-events: none;
  background: linear-gradient(180deg,
    rgba(43,36,54,0) 0rpx,
    rgba(43,36,54,0) 300rpx,
    rgba(43,36,54,0.6) 390rpx,
    #2b2436 450rpx);
}

/* 背景光斑（叠在下半部，补一点氛围光，不破坏统一色）*/
.bokeh {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(34% 20% at 82% 82%, rgba(180,90,255,0.14), transparent 72%),
    radial-gradient(40% 26% at 18% 95%, rgba(90,80,230,0.14), transparent 74%);
}

/* 顶栏 */
.topbar { position: relative; z-index: 1; display: flex; align-items: center; justify-content: space-between; padding: 10rpx 6rpx; }
.me { display: flex; align-items: center; gap: 16rpx; }
.me-av { width: 76rpx; height: 76rpx; border-radius: 50%; border: 2rpx solid rgba(255,255,255,0.35); }
.me-ph { display: flex; align-items: center; justify-content: center; font-size: 40rpx; background: rgba(255,255,255,0.1); }
.me-nick { font-size: 28rpx; font-weight: 700; color: #fff; }
.me-lv { font-size: 20rpx; color: #b9a7e6; margin-top: 2rpx; }
.top-actions { display: flex; gap: 14rpx; }
.top-btn {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 92rpx; height: 92rpx; border-radius: 26rpx; font-size: 20rpx; color: #d9c9ff;
  background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.14);
}
.top-ico { font-size: 34rpx; }

/* 品牌 */
.brand { position: relative; z-index: 1; text-align: center; padding: 12rpx 0 30rpx; }
.brand-logo {
  font-size: 64rpx; font-weight: 800; letter-spacing: 8rpx;
  background: linear-gradient(180deg, #fff, #c9b0ff); -webkit-background-clip: text; background-clip: text; color: transparent;
}
.brand-star { color: #ffcf4d; -webkit-text-fill-color: #ffcf4d; }
.brand-sub { font-size: 24rpx; color: #b9a7e6; margin-top: 6rpx; letter-spacing: 2rpx; }

/* 极简问候条 */
.userbar { position: relative; z-index: 1; display: flex; align-items: center; gap: 16rpx; padding: 6rpx 6rpx 10rpx; }
.ub-hi { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.9); letter-spacing: 1rpx; }
.ub-wave { font-size: 28rpx; }
.ub-av { width: 72rpx; height: 72rpx; }
.ub-img { width: 72rpx; height: 72rpx; border-radius: 50%; box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.35); }
.ub-ph { display: flex; align-items: center; justify-content: center; font-size: 38rpx; background: rgba(255,255,255,0.1); }

/* 剧本杀 · 招牌大横幅（夜幕氛围）：玻璃卡片框，立绘破框而出 */
.hero {
  position: relative; z-index: 1; height: 300rpx; margin-bottom: 12rpx;
  border-radius: 32rpx;
  background: linear-gradient(120deg, rgba(139,92,255,0.26), rgba(196,77,255,0.12));
  border: 1rpx solid rgba(255,255,255,0.2);
  box-shadow: 0 12rpx 30rpx rgba(0,0,0,0.35);
  transition: transform 0.12s ease;
}
.hero:active { transform: scale(0.98); }
/* 立绘容器：头顶冲出横幅上沿(破框)，随陀螺仪微动 */
.hero-man-wrap { position: absolute; right: -90rpx; bottom: -330rpx; width: 420rpx; height: 840rpx; z-index: 1;
  transition: transform 0.1s linear; }
.hero-man { position: absolute; left: 0; top: 0; width: 100%; height: 100%;
  filter: drop-shadow(0 10rpx 24rpx rgba(0,0,0,0.5)); }
.hero-body { position: absolute; left: 36rpx; top: 34rpx; z-index: 2; }
.hero-logo {
  display: inline-block; font-size: 44rpx; font-weight: 900; letter-spacing: 4rpx; line-height: 1.35;
  background: linear-gradient(95deg, #ffffff 0%, #ffb8d9 45%, #c99aff 100%);
  -webkit-background-clip: text; background-clip: text;
  color: transparent; -webkit-text-fill-color: transparent;
}
.hero-body .hero-logo { display: block; width: fit-content; }
.hero-sub { font-size: 22rpx; color: rgba(255,255,255,0.9); margin-top: 12rpx; letter-spacing: 1rpx; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5); }
.hero-join {
  display: inline-block; margin-top: 32rpx; font-size: 26rpx; font-weight: 700; color: #fff;
  padding: 14rpx 40rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #8b5cff, #c44dff); box-shadow: 0 6rpx 18rpx rgba(150,80,255,0.5);
}

/* 游戏卡 2×2 */
.cards { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 20rpx; }
.gcard {
  position: relative; overflow: hidden; border-radius: 32rpx; height: 270rpx;
  border: 1rpx solid rgba(255,255,255,0.16);
  box-shadow: 0 0 24rpx var(--ac), 0 12rpx 30rpx rgba(0,0,0,0.35);
  transition: transform 0.12s ease;
}
.gcard:active { transform: scale(0.97); }
/* 底层：整张模糊（露出的四周即模糊边） */
.gc-pic-blur { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0;
  filter: blur(50rpx) brightness(0.65); transform: scale(1.15); }
/* 上层：清晰图，缩进一圈，边缘羽化过渡 */
.gc-pic { position: absolute; inset: 0; width: 100%; height: 100%;
  border-radius: 32rpx; z-index: 0; filter: brightness(0.9);
  -webkit-mask-image: radial-gradient(120% 120% at 50% 50%, #000 40%, transparent 82%);
  mask-image: radial-gradient(120% 120% at 50% 50%, #000 40%, transparent 82%); }
/* 缩略图占位：与云图同位同遮罩，轻模糊掩住像素感，云图淡入后被盖住 */
.gc-pic-th { filter: blur(10rpx) brightness(0.9); }
/* 上下暗纱：顶部给标题、底部给人数/箭头 */
.gc-scrim { position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background: linear-gradient(180deg, rgba(10,6,20,0.72) 0%, transparent 32%, transparent 60%, rgba(10,6,20,0.78) 100%); }
/* 头部：图标 + 名字 */
.gc-head { position: absolute; left: 20rpx; top: 16rpx; z-index: 2; display: flex; align-items: center; gap: 10rpx; }
.gc-ico { font-size: 34rpx; filter: drop-shadow(0 2rpx 6rpx rgba(0,0,0,0.5)); }
.gc-name { font-size: 36rpx; font-weight: 800; color: #fff; letter-spacing: 1rpx; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.6); }
/* 副标题 */
.gc-sub { position: absolute; left: 20rpx; top: 62rpx; z-index: 2; font-size: 20rpx; color: rgba(225,212,255,0.85);
  text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.6); white-space: nowrap; overflow: hidden; max-width: 88%; }
/* 底部：人数胶囊 + 箭头 */
.gc-foot { position: absolute; left: 20rpx; right: 16rpx; bottom: 14rpx; z-index: 2;
  display: flex; align-items: center; justify-content: space-between; }
.gc-count { font-size: 19rpx; color: rgba(255,255,255,0.8); background: rgba(20,12,36,0.55); padding: 8rpx 18rpx; border-radius: 999rpx; }
.gc-go {
  width: 50rpx; height: 50rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 800; color: #fff; padding-bottom: 4rpx; box-sizing: border-box;
  background: var(--ac); box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.4);
}

/* 活动横幅 */
.banner {
  position: relative; z-index: 1; display: flex; align-items: center; gap: 20rpx; margin-top: 24rpx;
  border-radius: 30rpx; padding: 24rpx 28rpx; overflow: hidden;
  background: linear-gradient(120deg, rgba(180,90,255,0.30), rgba(255,90,180,0.20));
  border: 1rpx solid rgba(255,255,255,0.18);
}
.banner-emoji { font-size: 76rpx; flex: none; }
.banner-txt { flex: 1; }
.banner-t1 { font-size: 22rpx; color: rgba(255,255,255,0.85); }
.banner-t2 { font-size: 38rpx; font-weight: 800; color: #fff; margin-top: 4rpx; letter-spacing: 1rpx; }
.banner-go {
  flex: none; width: 96rpx; height: 96rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 800; color: #fff;
  background: linear-gradient(135deg, #ff4d94, #c44dff); box-shadow: 0 8rpx 22rpx rgba(255,77,148,0.55);
}

/* 系统公告 */
.notice {
  position: relative; z-index: 1; display: flex; align-items: center; gap: 14rpx; margin-top: 22rpx;
  border-radius: 999rpx; padding: 20rpx 28rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
}
.notice-tag { font-size: 22rpx; color: #d9c9ff; flex: none; }
.notice-txt { flex: 1; font-size: 22rpx; color: rgba(255,255,255,0.7); overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.notice-ar { color: rgba(255,255,255,0.4); font-size: 30rpx; }

/* 底部导航 */
.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 5;
  display: flex; padding: 14rpx 0 calc(14rpx + env(safe-area-inset-bottom));
  background: rgba(22,13,40,0.94); border-top: 1rpx solid rgba(255,255,255,0.08);
}
.tab { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; position: relative; color: #7c6fa0; font-size: 20rpx; }
.tab-ico { font-size: 40rpx; filter: grayscale(0.4) opacity(0.7); }
.tab.on { color: #fff; }
.tab.on .tab-ico { filter: none; }
.tab-badge {
  position: absolute; top: -6rpx; right: 34rpx; min-width: 26rpx; height: 26rpx; line-height: 26rpx;
  font-size: 18rpx; color: #fff; text-align: center; background: #ff4d6a; border-radius: 999rpx; padding: 0 6rpx;
}

/* ── 悬浮圆钮：回房间/进房间（可拖动） ── */
.fab {
  position: fixed; z-index: 50;
  width: 96rpx; height: 96rpx; line-height: 96rpx; text-align: center;
  border-radius: 50%; font-size: 48rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
  box-shadow: 0 8rpx 30rpx rgba(123, 92, 255, 0.45);
  transition: transform 0.1s ease;
}
.fab:active { transform: scale(0.92); }
.fab-back { background: linear-gradient(135deg, #ff4d7e, #ff85a8); box-shadow: 0 8rpx 30rpx rgba(255, 77, 126, 0.45); }

/* 快速进房弹框 */
.jmask { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center;
  background: rgba(10, 6, 20, 0.75); }
.jmodal { width: 78%; padding: 44rpx 36rpx; border-radius: 24rpx;
  background: #2a2140; border: 1rpx solid rgba(255, 255, 255, 0.12); }
.j-title { font-size: 34rpx; font-weight: 700; color: #ece8f5; text-align: center; }
.j-input { margin: 30rpx auto 0; height: 96rpx; border-radius: 16rpx; font-size: 40rpx; letter-spacing: 12rpx;
  text-align: center; color: #fff; background: rgba(255, 255, 255, 0.08); border: 1rpx solid rgba(255, 255, 255, 0.16); }
.j-tip { margin-top: 16rpx; text-align: center; font-size: 24rpx; color: #b3a6cc; }
.j-cancel { margin-top: 26rpx; height: 88rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 16rpx; font-size: 29rpx; font-weight: 600; color: #d9d2ec;
  background: transparent; border: 1rpx solid rgba(255, 255, 255, 0.25); }
.j-cancel::after { border: none; }
