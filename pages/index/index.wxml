<!-- 强制授权门：三步向导（头像 → 昵称 → 性别）-->
<view class="auth-mask" wx:if="{{needAuth}}" catchtouchmove="noop">
  <view class="auth-card">
    <view class="auth-close" catchtap="cancelEdit">✕</view>
    <view class="auth-steps">{{authStep}} / 3</view>

    <!-- 第一步：确认头像 -->
    <block wx:if="{{authStep===1}}">
      <view class="auth-title">第一步 · 确认头像</view>
      <view class="auth-sub">点下方选择你的微信头像</view>
      <button class="avatar-btn auth-avatar" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="avatar-ph">＋ 头像</view>
      </button>
      <button class="btn" bindtap="stepNext" disabled="{{uploading || !avatar}}">{{uploading ? '头像上传中…' : '下一步'}}</button>
    </block>

    <!-- 第二步：确认昵称 -->
    <block wx:elif="{{authStep===2}}">
      <view class="auth-title">第二步 · 确认昵称</view>
      <view class="auth-sub">点输入框，微信会带出你的昵称</view>
      <input class="input auth-input" type="nickname" placeholder="点这里填写微信昵称" value="{{nick}}" bindinput="onNick" bindblur="onNick" maxlength="8" />
      <view class="auth-btns">
        <button class="btn btn-ghost" bindtap="stepBack">上一步</button>
        <button class="btn" bindtap="stepNext" disabled="{{!nick}}">下一步</button>
      </view>
    </block>

    <!-- 第三步：选择性别 -->
    <block wx:else>
      <view class="auth-title">第三步 · 选择性别</view>
      <view class="auth-sub">决定你在剧中的角色照片</view>
      <view class="auth-gender">
        <view class="gender-opt {{gender==='m'?'on':''}}" data-g="m" bindtap="pickGender">♂ 男</view>
        <view class="gender-opt {{gender==='f'?'on':''}}" data-g="f" bindtap="pickGender">♀ 女</view>
      </view>
      <view class="auth-btns">
        <button class="btn btn-ghost" bindtap="stepBack">上一步</button>
        <button class="btn" bindtap="confirmAuth" disabled="{{!gender}}">{{editing ? '确定' : '完成进入'}}</button>
      </view>
    </block>
  </view>
</view>

<!-- 首页 = 剧本列表（免登录浏览）-->
<view class="pick-mask home-list">
  <view class="pick-head">
    <view>
      <view class="pick-h-title">剧本库</view>
      <view class="home-slogan muted">一局一故事，一人一面具</view>
    </view>
    <view class="home-head-right">
      <view class="home-guide-btn" bindtap="openGuide">❓ 怎么玩</view>
      <view class="home-me" bindtap="editProfile">
        <image wx:if="{{avatar}}" class="home-me-avatar" src="{{avatar}}" mode="aspectFill" />
        <view wx:else class="home-me-avatar home-me-ph">我</view>
      </view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="pick-search">
    <text class="pick-search-ico">🔍</text>
    <input class="pick-search-input" placeholder="搜剧本名 / 题材 / 人数" placeholder-class="pick-search-ph"
      value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
    <text wx:if="{{keyword}}" class="pick-search-clear" catchtap="clearSearch">✕</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="pick-cats" scroll-x>
    <view class="pick-cat {{activeCat===item ? 'on' : ''}}" wx:for="{{categories}}" wx:key="*this"
      data-cat="{{item}}" catchtap="selectCat">{{item}}</view>
  </scroll-view>

  <scroll-view class="pick-scroll" scroll-y>
    <view wx:if="{{!filteredScripts.length}}" class="pick-empty">没有匹配的剧本，换个分类或关键词试试</view>
    <view class="pick-card" wx:for="{{filteredScripts}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
      <view class="pick-cover" style="background:{{item.cover.gradient}}">
        <image wx:if="{{item.cover.image}}" class="cover-ph" src="/assets/cover_ph.jpg" mode="aspectFill"></image>
        <image wx:if="{{item.cover.image}}" class="pick-cover-img" src="{{item.cover.image}}" mode="aspectFill"></image>
        <view wx:if="{{item.cover.image}}" class="pick-cover-scrim"></view>
        <text wx:else class="pick-emoji">{{item.cover.emoji}}</text>
        <text class="pick-tag">{{item.tag}}</text>
        <text class="pick-cover-title">{{item.title}}</text>
      </view>
      <view class="pick-body">
        <view class="pick-sub">{{item.subtitle}}</view>
        <view class="pick-meta">{{item.players}} · {{item.duration}}</view>
      </view>
    </view>
    <view class="pick-bottom-tip">点封面看详情 → 详情页「创建房间」开局</view>
  </scroll-view>
</view>

<!-- 底部悬浮按钮 -->
<view class="fab-bar">
  <button class="fab" bindtap="enterRoom" disabled="{{loading}}">🚪 进入房间</button>
</view>

<!-- 新手指引弹层 -->
<view class="guide-mask" wx:if="{{showGuide}}" catchtouchmove="noop">
  <view class="guide-card">
    <view class="guide-title">🎭 三分钟看懂怎么玩</view>
    <scroll-view class="guide-body" scroll-y>
      <view class="guide-step">
        <view class="guide-h">这是什么</view>
        <view class="guide-p">微信群里玩的剧本杀——一群人围读一个故事，根据线索找出谁是凶手。</view>
      </view>
      <view class="guide-step">
        <view class="guide-h">① 开一局（你当房主 = 主持人）</view>
        <view class="guide-p">浏览剧本 → 选一个 → 点「创建房间」→ 点「分享到群」把卡片发群里，朋友点卡片就进房 → 人齐了点「开始游戏」，系统自动发角色。</view>
      </view>
      <view class="guide-step">
        <view class="guide-h">② 主持人做什么</view>
        <view class="guide-p">每一幕：照着手机提示，念剧情、把线索发到群、推进到下一幕；最后公布凶手和真相。手机上都有提示，照着做就行。</view>
      </view>
      <view class="guide-step">
        <view class="guide-h">③ 玩家做什么</view>
        <view class="guide-p">读自己角色的故事（只有你能看到）→ 在群里发言、互相盘问、找破绽 → 最后投票指认凶手。</view>
      </view>
      <view class="guide-step">
        <view class="guide-h">要几个人 · 多久</view>
        <view class="guide-p">看每个剧本（详情页有标）：一般 3–8 人、30–90 分钟。房主当主持人、不演角色。</view>
      </view>
    </scroll-view>
    <button class="btn guide-ok" bindtap="closeGuide">知道了，开始逛</button>
  </view>
</view>

<!-- 剧本详情层：看完再决定是否创建房间 -->
<view class="detail-mask" wx:if="{{showDetail}}">
  <view class="pick-head">
    <view class="detail-back" catchtap="closeDetail">‹ 返回</view>
    <view class="pick-h-title">剧本详情</view>
    <view class="pick-close" catchtap="closeDetail">✕</view>
  </view>
  <scroll-view class="detail-scroll" scroll-y wx:if="{{detail}}">
    <!-- 封面 -->
    <view class="detail-cover" style="background:{{detail.cover.gradient}}">
      <image wx:if="{{detail.cover.image}}" class="cover-ph" src="/assets/cover_ph.jpg" mode="aspectFill"></image>
      <image wx:if="{{detail.cover.image}}" class="pick-cover-img" src="{{detail.cover.image}}" mode="aspectFill"></image>
      <view wx:if="{{detail.cover.image}}" class="pick-cover-scrim"></view>
      <text wx:else class="detail-emoji">{{detail.cover.emoji}}</text>
      <text class="pick-tag">{{detail.tag}}</text>
      <text class="detail-cover-title">{{detail.title}}</text>
    </view>
    <view class="detail-sub">{{detail.subtitle}}</view>
    <view class="detail-meta">{{detail.players}} · {{detail.duration}}</view>

    <!-- 剧情简介 -->
    <view class="detail-sec-title">📖 剧情简介</view>
    <view class="detail-pre">{{detail.intro}}</view>

    <!-- 世界观背景 -->
    <block wx:if="{{detail.worldview}}">
      <view class="detail-sec-title">🌍 故事背景</view>
      <view class="detail-pre">{{detail.worldview}}</view>
    </block>

    <!-- 被害人 -->
    <block wx:if="{{detail.victim}}">
      <view class="detail-sec-title">💀 「被害人」</view>
      <view class="detail-pre">{{detail.victim}}</view>
    </block>

    <!-- 角色 -->
    <view class="detail-sec-title">🎭 出场角色（{{detail.roster.length}}）</view>
    <view class="detail-roles">
      <view class="detail-role" wx:for="{{detail.roster}}" wx:key="name">
        <text class="detail-role-name">{{item.name}}</text>
        <text class="detail-role-title">{{item.title}}</text>
      </view>
    </view>

    <!-- 人物关系 -->
    <block wx:if="{{detail.relations.length}}">
      <view class="detail-sec-title">🔗 人物关系</view>
      <view class="detail-rel" wx:for="{{detail.relations}}" wx:key="*this">{{item}}</view>
    </block>

    <view class="detail-tip">读完简介，确认开局 → 你将成为房主（主持人）</view>
  </scroll-view>

  <!-- 底部确认 -->
  <view class="detail-foot">
    <button class="btn btn-ghost detail-btn-back" bindtap="closeDetail">换一个</button>
    <button class="btn detail-btn-go" bindtap="confirmCreate" disabled="{{loading}}">用这个本创建房间</button>
  </view>
</view>
