.hero { padding: 40rpx 8rpx 8rpx; text-align: center; }
.hero .title { font-size: 56rpx; }
.hero .slogan { font-size: 46rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }
.hero .subtitle { margin-top: 14rpx; font-size: 26rpx; }

.resume {
  display: flex; align-items: center;
  background: linear-gradient(90deg, #6d4bd6, #a06be0);
  border-radius: 16rpx; padding: 24rpx 26rpx; margin-bottom: 24rpx;
}
.resume-main { flex: 1; }
.resume-title { font-size: 32rpx; font-weight: 600; color: #fff; }
.resume-sub { font-size: 24rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }
.resume-x { color: rgba(255,255,255,0.8); font-size: 32rpx; padding: 0 8rpx 0 20rpx; }

.label { font-size: 26rpx; color: #b3a6cc; margin-bottom: 14rpx; }

.auth-mask {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(12,9,20,0.92);
  display: flex; align-items: center; justify-content: center; padding: 48rpx;
}
.auth-card {
  position: relative;
  width: 100%; background: #241c33; border-radius: 28rpx;
  padding: 48rpx 40rpx; text-align: center;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.auth-close {
  position: absolute; top: 20rpx; right: 24rpx;
  width: 56rpx; height: 56rpx; line-height: 56rpx; text-align: center;
  font-size: 36rpx; color: #b3a6cc;
}
.auth-steps { font-size: 24rpx; color: #8a7da6; margin-bottom: 18rpx; letter-spacing: 2rpx; }
.auth-btns { display: flex; gap: 20rpx; }
.auth-btns .btn { flex: 1; margin: 0; }
.auth-title { font-size: 38rpx; font-weight: 600; color: #fff; }
.auth-sub { font-size: 26rpx; color: #b3a6cc; margin: 16rpx 0 36rpx; line-height: 1.5; }
.auth-avatar { width: 160rpx !important; height: 160rpx !important; margin: 0 auto 28rpx; }
.auth-input { margin-bottom: 24rpx; text-align: center; }
.auth-gender-label { font-size: 24rpx; color: #b3a6cc; margin-bottom: 14rpx; }
.auth-gender { display: flex; gap: 20rpx; margin-bottom: 32rpx; }
.gender-opt {
  flex: 1; text-align: center; padding: 22rpx 0; border-radius: 14rpx;
  font-size: 28rpx; color: #b3a6cc;
  background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.12);
}
.gender-opt.on { color: #fff; font-weight: 600; background: linear-gradient(90deg, #7b5cff, #c44dff); border-color: transparent; }
.auth-tip { font-size: 22rpx; color: #8a7da6; margin-top: 20rpx; }

.me-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 16rpx; }
/* 正圆头像按钮：强制正方形，清掉 button 默认内边距/边框 */
.avatar-btn {
  width: 96rpx; height: 96rpx; padding: 0 !important; margin: 0;
  box-sizing: border-box; flex: none; overflow: hidden;
  border-radius: 50%; line-height: 1; min-height: 0;
  background: rgba(0,0,0,0.25); border: 1rpx solid rgba(255,255,255,0.12);
}
.avatar-btn::after { display: none; border: none; }
.avatar-img { width: 100%; height: 100%; display: block; }
.avatar-ph {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: #b3a6cc;
}
.me-nick { flex: 1; }
.me-hint { font-size: 22rpx; color: #8a7da6; }

/* 头像昵称只读展示 */
.profile {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0 36rpx;
}
.profile-avatar {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: rgba(0,0,0,0.25); border: 1rpx solid rgba(255,255,255,0.12);
}
.profile-ph {
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #b3a6cc;
}
.profile-nick { margin-top: 20rpx; font-size: 34rpx; font-weight: 600; color: #fff; }
.profile-gender { font-size: 28rpx; color: #c4a8ff; font-weight: 400; }
.profile-edit { margin-top: 12rpx; font-size: 24rpx; color: #c4a8ff; }

/* 通栏大按钮：横向充满屏幕（抵消 .container 的左右 28rpx 内边距） */
.big-btn {
  width: calc(100% + 56rpx);
  margin-left: -28rpx; margin-right: -28rpx;
  box-sizing: border-box;
  margin-top: 28rpx; padding: 48rpx 0; font-size: 40rpx;
  border-radius: 16rpx;
}

/* 剧本封面卡片选择层 */
.pick-mask {
  position: fixed; inset: 0; z-index: 90;
  background: #15101f; display: flex; flex-direction: column;
}
.pick-head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 40rpx 36rpx 20rpx;
}
.pick-h-title { font-size: 38rpx; font-weight: 600; color: #fff; }
.pick-close { font-size: 40rpx; color: #b3a6cc; padding: 0 10rpx; }

/* 搜索框 */
.pick-search {
  display: flex; align-items: center;
  margin: 0 32rpx 16rpx; padding: 0 24rpx; height: 76rpx;
  background: #241c33; border-radius: 38rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.pick-search-ico { font-size: 28rpx; opacity: 0.6; margin-right: 14rpx; }
.pick-search-input { flex: 1; font-size: 28rpx; color: #fff; height: 76rpx; }
.pick-search-ph { color: #6f6385; }
.pick-search-clear { font-size: 30rpx; color: #b3a6cc; padding: 0 6rpx 0 16rpx; }

/* 分类标签 */
.pick-cats { white-space: nowrap; padding: 0 24rpx 8rpx; }
.pick-cat {
  display: inline-block; padding: 12rpx 30rpx; margin: 0 8rpx;
  font-size: 26rpx; color: #b3a6cc;
  background: #241c33; border-radius: 30rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}
.pick-cat.on {
  color: #fff; background: #6c4bd8; border-color: #6c4bd8;
}

.pick-empty { text-align: center; color: #6f6385; font-size: 28rpx; padding: 80rpx 0; }
.pick-scroll { flex: 1; min-height: 0; height: 0; padding: 8rpx 32rpx 48rpx; box-sizing: border-box; }

/* 首页=列表：页头小标语 + 「我的」入口 + 列表底部给悬浮条留白 */
.home-slogan { font-size: 24rpx; margin-top: 6rpx; }
.home-head-right { display: flex; align-items: center; gap: 18rpx; }
.home-guide-btn {
  font-size: 24rpx; color: #cdbcff;
  background: rgba(123,92,255,0.18); border: 1rpx solid rgba(123,92,255,0.4);
  padding: 10rpx 20rpx; border-radius: 999rpx;
}

/* 进入房间弹层（主题色）*/
.join-mask {
  position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 108;
  background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center;
  padding: 48rpx;
}
.join-card {
  position: relative; width: 100%; background: #241c33; border-radius: 28rpx;
  padding: 48rpx 40rpx 40rpx; text-align: center;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.join-close { position: absolute; top: 20rpx; right: 24rpx; font-size: 36rpx; color: #b3a6cc; padding: 6rpx 12rpx; }
.join-title { font-size: 38rpx; font-weight: 700; color: #fff; }
.join-sub { font-size: 26rpx; margin: 14rpx 0 32rpx; }
.join-input {
  height: 110rpx; background: #15101f; border-radius: 18rpx;
  border: 1rpx solid rgba(123,92,255,0.5);
  font-size: 56rpx; font-weight: 700; letter-spacing: 18rpx; text-align: center; color: #fff;
  margin-bottom: 32rpx; padding-left: 18rpx;
}
.join-ph { color: #5a5172; letter-spacing: 18rpx; font-weight: 700; }
.join-go { margin: 0; }

/* 新手指引弹层 */
.guide-mask {
  position: fixed; inset: 0; z-index: 110;
  background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center;
  padding: 48rpx;
}
.guide-card {
  width: 100%; max-height: 80vh; background: #241c33; border-radius: 28rpx;
  padding: 40rpx 36rpx; display: flex; flex-direction: column;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.guide-title { font-size: 36rpx; font-weight: 700; color: #fff; text-align: center; margin-bottom: 12rpx; }
.guide-body { flex: 1; min-height: 0; }
.guide-step { margin-top: 24rpx; }
.guide-h { font-size: 28rpx; font-weight: 600; color: #ffd9a8; margin-bottom: 8rpx; }
.guide-p { font-size: 26rpx; line-height: 1.6; color: #ddd6ee; }
.guide-ok { margin-top: 28rpx; }
.home-me { width: 72rpx; height: 72rpx; flex: none; }
.home-me-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: block; background: #241c33; border: 1rpx solid rgba(255,255,255,0.12); }
.home-me-ph { display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #b3a6cc; }
/* 底部悬浮按钮已去掉，列表铺满到底部（留常规安全边距） */
.home-list .pick-scroll { padding-bottom: 48rpx; }

/* 底部悬浮按钮 */
.fab-bar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 92;
  display: flex; gap: 20rpx;
  padding: 16rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent, #15101f 45%);
}
.fab {
  flex: 1; text-align: center; border-radius: 999rpx;
  font-size: 30rpx; font-weight: 600; padding: 24rpx 0; border: none;
  background: linear-gradient(90deg, #7b5cff, #c44dff); color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(108,75,216,0.4);
}
.fab::after { border: none; }
.fab-ghost { background: #2c2740; color: #e7e0f5; box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.3); }
.pick-card {
  background: #241c33; border-radius: 24rpx; overflow: hidden;
  margin-bottom: 28rpx; border: 1rpx solid rgba(255,255,255,0.08);
}
.pick-cover {
  position: relative; height: 240rpx; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
/* 封面占位：模糊小图，真封面下完自动盖上 */
.cover-ph { position: absolute; left: 0; top: 0; width: 100%; height: 100%; filter: blur(6rpx); transform: scale(1.12); }
.pick-cover-img { position: absolute; left: 0; top: 0; width: 100%; height: 100%; animation: kenburns 14s ease-in-out infinite alternate; }
@keyframes kenburns { from { transform: scale(1); } to { transform: scale(1.12); } }
.pick-cover-scrim {
  position: absolute; left: 0; top: 0; width: 100%; height: 100%;
  background: linear-gradient(180deg, rgba(0,0,0,0.15), transparent 38%, transparent 55%, rgba(0,0,0,0.6));
}
.pick-emoji { font-size: 110rpx; opacity: 0.92; }
.pick-tag {
  position: absolute; top: 20rpx; left: 24rpx;
  font-size: 22rpx; color: #fff; background: rgba(0,0,0,0.32);
  padding: 6rpx 16rpx; border-radius: 999rpx;
}
.pick-cover-title {
  position: absolute; left: 28rpx; bottom: 22rpx;
  font-size: 36rpx; font-weight: 700; color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.5);
}
.pick-body { padding: 22rpx 28rpx 26rpx; }
.pick-sub { font-size: 24rpx; color: #ddd6ee; }
.pick-meta { font-size: 24rpx; color: #8a7da6; margin-top: 12rpx; }
.pick-bottom-tip { text-align: center; font-size: 24rpx; color: #8a7da6; padding: 8rpx 0 24rpx; }

/* ===== 剧本详情层 ===== */
.detail-mask {
  position: fixed; inset: 0; z-index: 95;
  background: #15101f; display: flex; flex-direction: column;
}
.detail-back { font-size: 30rpx; color: #b3a6cc; padding: 0 10rpx; }
.detail-scroll { flex: 1; min-height: 0; height: 0; padding: 0 32rpx 24rpx; box-sizing: border-box; }
.detail-cover {
  position: relative; height: 300rpx; border-radius: 24rpx; overflow: hidden;
  display: flex; align-items: center; justify-content: center; margin-top: 8rpx;
}
.detail-emoji { font-size: 128rpx; opacity: 0.92; }
.detail-cover-title {
  position: absolute; left: 28rpx; bottom: 24rpx;
  font-size: 40rpx; font-weight: 700; color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.5);
}
.detail-sub { font-size: 26rpx; color: #ddd6ee; margin-top: 24rpx; }
.detail-meta { font-size: 22rpx; color: #8a7da6; margin-top: 10rpx; }
.detail-sec-title {
  font-size: 28rpx; font-weight: 600; color: #fff;
  margin: 34rpx 0 14rpx;
}
.detail-pre {
  font-size: 25rpx; line-height: 1.7; color: #cfc6e2;
  white-space: pre-wrap; word-break: break-word;
}
.detail-roles { display: flex; flex-direction: column; gap: 12rpx; }
.detail-role {
  display: flex; align-items: baseline;
  background: #241c33; border-radius: 16rpx; padding: 18rpx 24rpx;
  border: 1rpx solid rgba(255,255,255,0.07);
}
.detail-role-name { font-size: 26rpx; font-weight: 600; color: #fff; margin-right: 18rpx; }
.detail-role-title { font-size: 22rpx; color: #9a8db8; }
.detail-rel {
  font-size: 24rpx; line-height: 1.65; color: #bcb1d4;
  padding: 8rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.detail-tip { text-align: center; font-size: 22rpx; color: #8a7da6; padding: 36rpx 0 8rpx; }
.detail-foot {
  display: flex; gap: 20rpx; padding: 18rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255,255,255,0.06); background: #15101f;
}
.detail-btn-back { flex: 0 0 200rpx; }
.detail-btn-go { flex: 1; }
.input {
  background: rgba(0,0,0,0.25);
  border: 1rpx solid rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  color: #fff;
}

.scripts { display: flex; flex-direction: column; gap: 18rpx; }
.script {
  position: relative; padding: 24rpx 26rpx; border-radius: 18rpx;
  background: rgba(0,0,0,0.22); border: 1rpx solid rgba(255,255,255,0.1);
}
.script.on { border-color: #c44dff; background: rgba(196,77,255,0.16); }
.s-head { display: flex; align-items: center; gap: 14rpx; }
.s-title { font-size: 32rpx; font-weight: 700; }
.s-tag { font-size: 20rpx; color: #cdbcff; background: rgba(123,92,255,0.25); border-radius: 999rpx; padding: 2rpx 14rpx; }
.s-sub { font-size: 25rpx; color: #c3b8db; margin-top: 8rpx; }
.s-meta { font-size: 23rpx; color: #9a8fb5; margin-top: 8rpx; }
.s-check { position: absolute; top: 22rpx; right: 24rpx; color: #c44dff; font-size: 34rpx; font-weight: 700; }

.howto { margin-top: 40rpx; padding: 0 8rpx; }
.howto-title { font-size: 28rpx; color: #cdbcff; margin-bottom: 16rpx; font-weight: 600; }
.howto .muted { line-height: 2; }

/* 详情浮层：去掉自绘头，封面铺满顶部（点封面可返回） */
.detail-mask .detail-scroll { padding-top: 0; }
