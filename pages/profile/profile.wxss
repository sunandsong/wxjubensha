page { background: #2b2436; }
.page { padding: 60rpx 40rpx; }

.sec { margin-bottom: 56rpx; text-align: center; }

/* 头像按钮：彻底去掉 button 默认样式；整块(头像+提示文字)都可点 */
.av-btn { display: block; width: auto !important; min-width: 0; min-height: 0;
  padding: 0; margin: 0 auto; line-height: 1; font-size: 0;
  background: transparent !important; border: none; box-sizing: border-box; overflow: visible; }
.av-btn::after { border: none; }
.av-wrap { position: relative; width: 180rpx; height: 180rpx; margin: 0 auto; }
.av-img { width: 180rpx; height: 180rpx; border-radius: 50%; display: block;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.4); }
.av-ph { display: flex; align-items: center; justify-content: center; font-size: 80rpx;
  background: rgba(255,255,255,0.1); }
.av-badge { position: absolute; right: 0; bottom: 0; width: 52rpx; height: 52rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #fff;
  background: linear-gradient(135deg, #8b5cff, #c44dff); border: 3rpx solid #2b2436; }
.av-tip { margin-top: 18rpx; font-size: 24rpx; color: #b9a7e6; }

/* 头像加载中：半透明遮罩 + 转圈 */
.av-loading { position: absolute; inset: 0; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  background: rgba(30,22,48,0.55); }
.spin { width: 44rpx; height: 44rpx; border-radius: 50%;
  border: 5rpx solid rgba(255,255,255,0.25); border-top-color: #c99aff;
  animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.label { text-align: left; font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 18rpx; }
.label-sub { font-size: 22rpx; font-weight: 400; color: #b9a7e6; }

.input { box-sizing: border-box; width: 100%; height: 96rpx; padding: 0 28rpx; border-radius: 22rpx;
  font-size: 30rpx; color: #fff; background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.16); }

.genders { display: flex; gap: 20rpx; }
.g-opt { flex: 1; height: 96rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 22rpx; font-size: 30rpx; color: rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.16); }
.g-opt.on { color: #fff; font-weight: 700;
  background: linear-gradient(135deg, rgba(139,92,255,0.55), rgba(196,77,255,0.45));
  border-color: rgba(255,255,255,0.4); }

.save { margin-top: 20rpx; width: 100%; height: 96rpx; display: flex; align-items: center; justify-content: center; border-radius: 999rpx;
  font-size: 32rpx; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, #8b5cff, #c44dff); box-shadow: 0 8rpx 22rpx rgba(150,80,255,0.45); }
.save::after { border: none; }
