<view wx:if="{{testTag}}" class="test-switch" bindtap="gotoTest">切换身份·{{testTag}}</view>

<view class="container">
  <!-- 抓对真凶撒花 -->
  <view class="confetti" wx:if="{{caught}}">
    <view class="confetti-piece" wx:for="{{confetti}}" wx:key="i"
          style="left:{{item.left}}%;background:{{item.color}};animation-delay:{{item.delay}}s;animation-duration:{{item.dur}}s;"></view>
  </view>

  <view class="verdict {{caught?'win':'lose'}}">
    <view class="verdict-icon">{{caught ? '🎉' : '🕵️'}}</view>
    <view class="verdict-text">{{caught ? '真凶落网！' : '凶手逃脱了…'}}</view>
    <view class="muted">大家指认：{{accusedName}}　·　真凶：{{murdererName}}</view>
    <view class="muted" wx:if="{{!isHost}}">最后还有一封信，由主持人念给大家</view>
  </view>

  <view class="card my-result" wx:if="{{myResult}}">{{myResult}}</view>

  <view class="card">
    <view class="sec-title">投票结果</view>
    <view class="tally-item" wx:for="{{tally}}" wx:key="name">
      <view class="t-name">
        {{item.name}}<text class="t-title">{{item.title}}</text>
        <text class="t-player" wx:if="{{item.playerNick}}">· {{item.playerNick}}</text>
        <text class="t-killer" wx:if="{{item.isMurderer}}">真凶</text>
      </view>
      <view class="t-count">{{item.count}} 票</view>
    </view>
  </view>

  <!-- 真相（第一~六章）：所有人都能看到 -->
  <view class="card truth">
    <view class="sec-title">{{truth.title}}</view>
    <view class="pre">{{truth.text}}</view>
  </view>

  <!-- 张涛的诊断报告：先揭晓「他早已查出晚期癌症」-->
  <view class="card truth letter" wx:if="{{isHost}}">
    <view class="row-between">
      <view class="sec-title">🏥 张涛的诊断报告（仅主持人）</view>
      <text class="muted">先揭晓</text>
    </view>
    <view class="letter-stub">
      <view class="letter-icon">🏥</view>
      <view class="muted">证明老板早已查出晚期癌症。先下载这张发群，再放下面那封信。</view>
    </view>
    <view class="clue-actions">
      <text class="mini-btn" bindtap="saveReportImg">下载诊断报告（图片）</text>
    </view>
  </view>

  <!-- 遗书：压轴，放在诊断报告之后揭晓 -->
  <view class="card truth letter" wx:if="{{isHost && (letter || letterImg)}}">
    <view class="row-between">
      <view class="sec-title">✉️ 张涛留下的那封信（仅主持人）</view>
      <text class="muted">最后揭晓</text>
    </view>
    <view class="letter-stub">
      <view class="letter-icon">✉️</view>
      <view class="muted">信的内容不在这里显示。点下方按钮下载成图片，最后念给大家 / 发到群里。</view>
    </view>
    <view class="clue-actions">
      <text class="mini-btn" bindtap="saveLetterImg">下载这封信（图片）</text>
    </view>
  </view>

  <!-- 离屏 canvas：渲染信 / 报告单用，不显示 -->
  <canvas type="2d" id="letterCanvas" class="offscreen-canvas"></canvas>
  <canvas type="2d" id="reportCanvas" class="offscreen-canvas"></canvas>

  <button wx:if="{{isHost}}" class="btn" bindtap="endGame">结束游戏（解散房间）</button>
  <button wx:else class="btn btn-ghost" bindtap="backHome">返回首页</button>
</view>
