
<view class="container">
  <!-- ====== 玩家：只显示一句「等待主持人公布真相」 ====== -->
  <block wx:if="{{!isHost}}">
    <view class="wait-screen">
      <view class="wait-icon">🕵️</view>
      <view class="wait-text">去群里等待主持人公布真相</view>
    </view>
  </block>

  <!-- ====== 主持人：完整结算 ====== -->
  <block wx:else>
    <!-- 破晓天光：真相揭晓,黑夜退场 -->
    <view class="dawn-sky"></view>
    <!-- 抓对真凶撒花 -->
    <view class="confetti" wx:if="{{caught}}">
      <view class="confetti-piece" wx:for="{{confetti}}" wx:key="i"
            style="left:{{item.left}}%;background:{{item.color}};animation-delay:{{item.delay}}s;animation-duration:{{item.dur}}s;"></view>
    </view>

    <view class="verdict {{caught?'win':'lose'}}">
      <view class="verdict-icon">{{caught ? '🎉' : '🕵️'}}</view>
      <view class="verdict-text">{{caught ? '真凶落网！' : '凶手逃脱了…'}}</view>
    </view>

    <view class="card">
      <view class="sec-title">投票结果</view>
      <view class="tally-item" wx:for="{{tally}}" wx:key="name" style="animation-delay:{{index * 120}}ms">
        <view class="t-name">
          {{item.name}}<text class="t-title">{{item.title}}</text>
          <text class="t-player" wx:if="{{item.playerNick}}">· {{item.playerNick}}</text>
          <text class="t-killer" wx:if="{{item.isMurderer}}">真凶</text>
        </view>
        <view class="t-count">{{item.count}} 票</view>
      </view>
    </view>

    <!-- 主持人提示 -->
    <view class="card host-note">
      <view class="note-line"><text class="note-warn">其他玩家看不到真相、也看不到投票结果</text>——点击「一键复制」，发到群里进行公布。</view>
    </view>

    <!-- 一键复制（结果+真相+信）发群 -->
    <button class="btn" bindtap="copyTruthLetter">一键复制</button>
    <button class="btn btn-ghost" bindtap="endGame">结束游戏</button>
  </block>
</view>

<id-switch />
