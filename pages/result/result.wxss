.verdict { text-align: center; padding: 40rpx 0 10rpx; }
.verdict-icon { font-size: 96rpx; }
.verdict-text { font-size: 44rpx; font-weight: 700; margin: 12rpx 0 8rpx; }
.verdict.win .verdict-text { color: #7CFFB2; }
.verdict.lose .verdict-text { color: #ff8a8a; }

.my-result { text-align: center; font-size: 30rpx; font-weight: 600; color: #ffd9a8; }

.sec-title { font-size: 32rpx; font-weight: 700; margin-bottom: 16rpx; }

.tally-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.tally-item:last-child { border-bottom: none; }
.t-name { font-size: 30rpx; font-weight: 600; }
.t-title { font-size: 22rpx; color: #b3a6cc; margin-left: 12rpx; font-weight: 400; }
.t-player { font-size: 22rpx; color: #8a7da6; margin-left: 10rpx; font-weight: 400; }
.t-killer { font-size: 20rpx; color: #ff8a8a; border: 1rpx solid rgba(255,138,138,0.5); border-radius: 999rpx; padding: 2rpx 12rpx; margin-left: 12rpx; }
.t-count { font-size: 28rpx; color: #cdbcff; }

.truth { border: 1rpx solid rgba(196,77,255,0.35); }
.letter { border-color: rgba(255,196,77,0.45); }
.row-between { display: flex; align-items: center; justify-content: space-between; }
.tip { margin: 12rpx 0; }
.letter-img { width: 100%; border-radius: 14rpx; margin-top: 12rpx; display: block; }

/* 遗书：不展示内容，只放图标 + 下载按钮 */
.letter-stub { display: flex; align-items: center; gap: 18rpx; margin-top: 12rpx; }
.letter-icon { font-size: 64rpx; flex: none; }

/* 下载按钮 */
.clue-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.mini-btn {
  align-self: flex-start; line-height: 1.7;
  background: rgba(123,92,255,0.3); color: #ddd2ff;
  font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 999rpx;
}

/* 离屏 canvas：渲染信件用，移出屏幕不显示 */
.offscreen-canvas {
  position: fixed; left: -9999rpx; top: 0;
  width: 720px; height: 1600px;
}

/* 揭晓动画：图标弹入 + 文字淡上 */
@keyframes popIn { 0% { transform: scale(0); opacity: 0; } 60% { transform: scale(1.18); } 100% { transform: scale(1); opacity: 1; } }
.verdict-icon { animation: popIn 0.6s cubic-bezier(.2,.8,.2,1.2) both; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(16rpx); } to { opacity: 1; transform: none; } }
.verdict-text { animation: fadeUp 0.5s ease 0.28s both; }

/* 撒花 */
.confetti { position: fixed; left: 0; top: 0; width: 100%; height: 0; z-index: 60; pointer-events: none; }
.confetti-piece {
  position: absolute; top: -40rpx; width: 14rpx; height: 22rpx; border-radius: 3rpx;
  animation-name: confettiFall; animation-timing-function: linear; animation-fill-mode: forwards;
}
@keyframes confettiFall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(1150rpx) rotate(560deg); opacity: 0; }
}
