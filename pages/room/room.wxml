
<view class="container">
  <!-- 剧本名 -->
  <view class="rm-script">{{scriptTitle}}</view>

  <!-- 房间号大字 -->
  <view class="codebox">
    <view class="code-lab">房 间 号</view>
    <view class="code-big">{{roomCode}}</view>
  </view>
  <view class="rm-narr">人齐了，故事就开始</view>

  <!-- 玩家网格：已准备=紫勾章，空位=虚线圈 -->
  <view class="rm-players">
    <view class="player" wx:for="{{players}}" wx:key="openid">
      <view class="avatar">
        <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
        <block wx:else>{{item.nick[0]}}</block>
        <view class="okmark" wx:if="{{item.ready && !item.isModerator && !item.spectator}}">✓</view>
      </view>
      <view class="host-badge" wx:if="{{item.isModerator}}">主持人</view>
      <view class="pname">{{item.nick}}</view>
    </view>
    <view class="player" wx:for="{{emptySlots}}" wx:key="*this">
      <view class="avatar slot-empty">?</view>
      <view class="pname pname-dim">等待中</view>
    </view>
  </view>

  <!-- 房主视角 -->
  <block wx:if="{{isHost}}">
    <view wx:if="{{!canStart}}" class="muted center rm-count">{{realCount < needPlayers ? '还差 ' + (needPlayers - realCount) + ' 名玩家 · 主持人不占角色' : '等待玩家准备 ' + readyCount + '/' + realCount}}</view>
    <button hover-class="none" class="btn start-btn {{(!canStart || starting) ? 'btn-dim' : ''}}" bindtap="startGame">开始游戏</button>
    <button hover-class="none" class="btn btn-ghost" open-type="share">分享链接 · 邀请群友</button>
    <button hover-class="none" class="btn btn-ghost btn-slim" bindtap="endGame">解散房间</button>
  </block>
  <!-- 玩家视角 -->
  <block wx:else>
    <button hover-class="none" wx:if="{{!iAmSpectator}}" class="btn start-btn {{myReady ? 'btn-ghost' : ''}}" bindtap="toggleReady">{{myReady ? '已准备（点击取消）' : '准备好了'}}</button>
    <view class="muted center rm-count">{{iAmSpectator ? '你是围观，等主持人开始…' : (myReady ? '已准备，等所有人准备好主持人就开始' : '点「准备好了」，全员准备后主持人才能开始')}}</view>
    <button hover-class="none" class="btn btn-ghost btn-slim" bindtap="leaveRoom">退出房间</button>
  </block>
</view>

<id-switch />
