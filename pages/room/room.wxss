/* 房间等待 —— 简洁方案：房间号是主角，玻璃卡 + 紫渐变主按钮（对齐设计稿） */

page { background: radial-gradient(85% 45% at 50% 0%, rgba(140, 100, 255, 0.12), transparent 62%), #1e1830; }

/* ── 顶部：剧本名 + 房间号大字 + 旁白 ── */
.rm-script { text-align: center; font-size: 44rpx; font-weight: 700; color: #fff; margin-top: 12rpx; letter-spacing: 4rpx; }
.codebox { text-align: center; margin: 34rpx 0 4rpx; }
.code-lab { font-size: 22rpx; letter-spacing: 10rpx; color: #8a7fa6; }
.code-big {
  font-size: 140rpx; font-weight: 900; letter-spacing: 30rpx; color: #fff; line-height: 1.35;
  text-shadow: 0 0 50rpx rgba(140, 100, 255, 0.45);
}
.rm-narr { text-align: center; font-size: 25rpx; color: #b3a6cc; margin-bottom: 26rpx; }

/* ── 玩家网格：不包卡片，头像居中 ── */
.rm-players { display: flex; flex-wrap: wrap; justify-content: center; gap: 28rpx 30rpx; margin: 8rpx 0 4rpx; }
.player { position: relative; width: 120rpx; text-align: center; }
.avatar {
  position: relative;
  width: 96rpx; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  border-radius: 50%; font-size: 40rpx; color: #fff; overflow: visible;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
}
.avatar .avatar-img { width: 96rpx; height: 96rpx; display: block; border-radius: 50%; }
.pname { font-size: 24rpx; margin-top: 12rpx; color: #ddd6ee; line-height: 1.3; word-break: break-all; }
.pname-dim { color: #8a7fa6; }

/* 已准备/主持人：紫圆勾章，盖头像右上角 */
.okmark {
  position: absolute; right: -6rpx; top: -6rpx; z-index: 2;
  width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center;
  border-radius: 50%; font-size: 22rpx; color: #fff;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
  border: 2rpx solid #1e1830;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.45);
}

/* 空位：虚线圈 */
.avatar.slot-empty {
  background: none; border: 2rpx dashed rgba(255, 255, 255, 0.25);
  color: #8a7fa6; font-size: 34rpx; box-sizing: border-box;
}

/* 主持人角标 */
.host-badge {
  position: absolute; top: -14rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; white-space: nowrap; z-index: 3;
  background: #ffb347; color: #3a2a00; border-radius: 999rpx; padding: 2rpx 12rpx;
}

.center { text-align: center; }
.warn { color: #ffb347; }
.rm-count { margin-top: 20rpx; }

/* ── 按钮：主按钮紫渐变（全局），整宽 ── */
.btn { width: 100% !important; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.start-btn { margin-top: 36rpx; padding: 44rpx 0; font-size: 36rpx; }
/* 不可用态：仍可点击，点击提示差什么 */
.btn-dim { opacity: 0.55; }
