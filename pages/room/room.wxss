.script-card .sc-title { font-size: 38rpx; font-weight: 700; margin: 8rpx 0; }
.code-row { display: flex; align-items: center; justify-content: space-between; }
.code { font-size: 56rpx; font-weight: 700; letter-spacing: 12rpx; color: #fff; margin-top: 8rpx; }
.btn-mini {
  background: rgba(123,92,255,0.3); color: #ddd2ff; font-size: 26rpx;
  padding: 12rpx 28rpx; border-radius: 999rpx; line-height: 1.6;
}
.btn-mini::after { border: none; }
.code-actions { display: flex; gap: 14rpx; align-items: center; }
.btn-mini.share { background: linear-gradient(90deg, #7b5cff, #c44dff); color: #fff; }
.invite-tip { margin-top: 18rpx; }

.row-between { display: flex; align-items: center; justify-content: space-between; }
.sec-title { font-size: 30rpx; font-weight: 600; }
.tip { margin-top: 20rpx; }

.players { display: flex; flex-wrap: wrap; gap: 24rpx; margin-top: 24rpx; }
.player { position: relative; width: 120rpx; text-align: center; }
.avatar {
  width: 96rpx; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  border-radius: 50%; font-size: 40rpx; color: #fff; overflow: hidden;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
}
.avatar .avatar-img { width: 96rpx; height: 96rpx; display: block; }
.pname { font-size: 24rpx; margin-top: 10rpx; color: #ddd6ee; line-height: 1.3; word-break: break-all; }
.host-badge {
  position: absolute; top: -8rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; white-space: nowrap;
  background: #ffb347; color: #3a2a00; border-radius: 999rpx; padding: 2rpx 10rpx;
}
.center { text-align: center; margin-top: 28rpx; }
.warn { color: #ffb347; }

/* 准备状态角标（头像下方）*/
.ready-badge {
  margin-top: 8rpx; font-size: 18rpx; white-space: nowrap;
  display: inline-block; padding: 2rpx 12rpx; border-radius: 999rpx;
  color: #b3a6cc; background: rgba(255,255,255,0.08);
}
.ready-badge.on { color: #1c3b22; background: #7fe0a8; }
.ready-hint { margin-bottom: -8rpx; }

/* 开始 / 结束游戏：整宽，和上方卡片对齐 */
.btn { width: 100% !important; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.start-btn { margin-top: 32rpx; }

/* 开始按钮不可用态：仍可点击，点击会提示差什么（disabled 会吞掉点击导致无反馈） */
.btn-dim { opacity: 0.55; }

/* ══ 光影·一根线 ══ */
page { background: #17121f; }
/* 星空底图：星座连线 = 玩家逐个就位;云图淡入 */
.scene-bg { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0;
  opacity: 0; transition: opacity 0.8s ease; pointer-events: none; }
.scene-bg.on { opacity: 0.55; }
.card, .btn, .ready-hint, .wait-hint, .center, .dev-upload { position: relative; z-index: 1; }
/* 剧本名下:一根发光的线划过 */
.sc-title::after { content: ""; display: block; width: 140rpx; height: 2rpx; margin-top: 12rpx;
  background: linear-gradient(90deg, #cabdff, transparent); box-shadow: 0 0 10rpx rgba(165,139,255,0.6); }
/* 席位:未就位沉在暗处,就位=光点亮+线绕一圈打结 */
.player .avatar { position: relative; overflow: visible; transition: filter 0.4s; filter: grayscale(0.7) brightness(0.45); }
.player.lit .avatar { filter: none; }
.player.lit .avatar::after { content: ""; position: absolute; left: -10rpx; top: -10rpx; right: -10rpx; bottom: -10rpx;
  border-radius: 50%; border: 2rpx dashed rgba(202,189,255,0.85);
  box-shadow: 0 0 16rpx rgba(165,139,255,0.5); animation: knotIn 0.5s cubic-bezier(0.2, 1.6, 0.4, 1); }
@keyframes knotIn { 0% { transform: scale(0.4); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
.player .pname { transition: color 0.4s; color: rgba(236,232,245,0.4); }
.player.lit .pname { color: #ece8f5; }
/* 开始按钮:一束光的颜色 */
.start-btn { background: linear-gradient(135deg, #f2eeff, #cabdff) !important; color: #241d3a !important;
  box-shadow: 0 0 34rpx rgba(165,139,255,0.35); }
.start-btn.btn-dim { opacity: 0.45; }

/* 一次性上传按钮（跑完删除） */
.dev-upload { margin: 40rpx auto 0; width: 80%; font-size: 26rpx; color: #fff;
  background: rgba(255,255,255,0.14); border: 1rpx solid rgba(255,255,255,0.3); border-radius: 999rpx; }

/* 卡片/按钮实底：星空只在缝隙里,不透进内容 */
.card { background: #272040; border: 1rpx solid rgba(255,255,255,0.15); }
.btn-ghost { background: #272040; }
.dev-upload { background: #272040; }
