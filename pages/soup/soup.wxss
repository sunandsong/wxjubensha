page { background: #1d1730; }
.page { position: relative; min-height: 100vh; padding: 0 32rpx 60rpx; box-sizing: border-box; overflow: hidden; }

/* 外星酒馆氛围底图：全屏垫底,云图加载完淡入 */
.scene-bg { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0;
  opacity: 0; transition: opacity 0.6s ease; }
.scene-bg.on { opacity: 0.22; }
.tavernline, .h-row, .flavors, .empty-state, .soup-zone { position: relative; z-index: 1; }

/* ── 顶部舷窗条 ── */
.tavernline { height: 150rpx; margin: 0 -32rpx 20rpx; overflow: hidden;
  background: linear-gradient(180deg, #100c22 0%, #221a3e 78%, rgba(29,23,48,0) 100%); }
.tstar { position: absolute; width: 4rpx; height: 4rpx; border-radius: 50%; background: #fff; opacity: 0.7;
  animation: twk 3s ease-in-out infinite; }
.tstar.s1 { left: 46%; top: 28rpx; } .tstar.s2 { left: 62%; top: 62rpx; animation-delay: 1s; } .tstar.s3 { left: 78%; top: 22rpx; animation-delay: 2s; }
@keyframes twk { 0%, 100% { opacity: 0.7; } 50% { opacity: 0.15; } }
.neon { position: absolute; left: 36rpx; top: 34rpx; font-size: 30rpx; font-weight: 800; letter-spacing: 6rpx;
  color: #ff7ac2; text-shadow: 0 0 20rpx rgba(255,122,194,0.8), 0 0 52rpx rgba(255,122,194,0.4);
  animation: neonflick 4.5s ease-in-out infinite; }
.neon-sub { display: block; font-size: 17rpx; letter-spacing: 8rpx; color: #7fd0ff;
  text-shadow: 0 0 16rpx rgba(77,184,255,0.7); margin-top: 6rpx; font-weight: 400; }
@keyframes neonflick { 0%,100% { opacity: 1; } 92% { opacity: 1; } 94% { opacity: 0.45; } 96% { opacity: 1; } 98% { opacity: 0.7; } }

/* 特调杯：云端发光杯(黑底用 screen 混合融进夜色) + CSS 活气泡 */
.cupwrap { position: absolute; right: 36rpx; bottom: 10rpx; width: 100rpx; height: 120rpx; }
.cup-img { width: 100rpx; height: 110rpx; mix-blend-mode: screen; }
.cup-css { position: absolute; left: 16rpx; bottom: 0; width: 68rpx; height: 88rpx;
  border: 4rpx solid rgba(160,200,255,0.55); border-top: none; border-radius: 0 0 24rpx 24rpx;
  background: linear-gradient(180deg, rgba(77,184,255,0.12) 30%, rgba(77,184,255,0.4)); }
.bub { position: absolute; bottom: 78rpx; border-radius: 50%; background: rgba(200,230,255,0.9);
  animation: rise linear infinite; }
.bub.b1 { left: 22rpx; width: 6rpx; height: 6rpx; animation-duration: 2.3s; }
.bub.b2 { left: 44rpx; width: 10rpx; height: 10rpx; animation-duration: 3.4s; animation-delay: 0.7s; }
.bub.b3 { left: 66rpx; width: 8rpx; height: 8rpx; animation-duration: 2.8s; animation-delay: 1.5s; }
.bub.b4 { left: 32rpx; width: 5rpx; height: 5rpx; animation-duration: 2s; animation-delay: 1.1s; }
/* 摇摆上升,越升越大,到顶"啵"地放大消失 */
@keyframes rise {
  0% { transform: translate(0, 0) scale(0.55); opacity: 0; }
  12% { opacity: 0.95; }
  38% { transform: translate(4rpx, -26rpx) scale(0.8); }
  66% { transform: translate(-4rpx, -50rpx) scale(1); opacity: 0.9; }
  90% { transform: translate(2rpx, -68rpx) scale(1.2); opacity: 0.55; }
  100% { transform: translate(2rpx, -76rpx) scale(1.5); opacity: 0; }
}

/* ── 标题行 / 口味 ── */
.h-row { display: flex; justify-content: space-between; align-items: baseline; margin: 24rpx 4rpx 14rpx; }
.h-b { font-size: 26rpx; font-weight: 700; letter-spacing: 2rpx; color: #ece8f5; }
.h-s { font-size: 20rpx; color: #9d8fbe; }
.flavors { display: flex; gap: 16rpx; }
.fl { flex: 1; height: 76rpx; border-radius: 999rpx; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 600; color: #9d8fbe; background: rgba(255,255,255,0.055);
  border: 1rpx solid rgba(255,255,255,0.13); transition: all 0.25s; }
.fl:active { transform: scale(0.96); }
.fl.on { color: #fff; background: rgba(77,184,255,0.18); border-color: rgba(77,184,255,0.55); }
.fl.hong.on { background: rgba(255,106,92,0.16); border-color: rgba(255,106,92,0.55); }

/* ── 空碗态 ── */
.empty-state { margin-top: 28rpx; border-radius: 36rpx; padding: 68rpx 32rpx 60rpx; text-align: center;
  border: 3rpx dashed rgba(255,255,255,0.13); background: rgba(255,255,255,0.03); }
.empty-state .bowl { font-size: 104rpx; animation: bowlfloat 3.5s ease-in-out infinite; }
@keyframes bowlfloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12rpx); } }
.empty-state .t1 { font-size: 27rpx; font-weight: 700; color: #ece8f5; margin-top: 20rpx; letter-spacing: 2rpx; }
.empty-state .t2 { font-size: 21rpx; color: #9d8fbe; margin-top: 10rpx; line-height: 1.8; }
.resume-link { display: inline-block; margin-top: 26rpx; font-size: 23rpx; font-weight: 600; color: #7fd0ff;
  padding: 12rpx 36rpx; border-radius: 999rpx; border: 1rpx solid rgba(77,184,255,0.4); }

/* ── 端汤上桌 ── */
.soup-zone { animation: serve 0.45s cubic-bezier(0.2, 1.2, 0.4, 1); }
@keyframes serve { 0% { opacity: 0; transform: translateY(36rpx); } 100% { opacity: 1; transform: none; } }
.soup-card { position: relative; margin-top: 20rpx; border-radius: 36rpx; padding: 34rpx 32rpx 38rpx;
  background: rgba(255,255,255,0.075); border: 1rpx solid rgba(255,255,255,0.13); }
.sc-head { display: flex; justify-content: space-between; align-items: baseline; gap: 20rpx; }
.sc-title { font-size: 34rpx; font-weight: 800; letter-spacing: 2rpx; color: #fff; }
.sc-tags { flex: none; display: flex; gap: 10rpx; }
.sc-tag { font-size: 19rpx; padding: 4rpx 18rpx; border-radius: 999rpx; font-weight: 600;
  color: #7fd0ff; background: rgba(77,184,255,0.12); border: 1rpx solid rgba(77,184,255,0.32); }
.sc-tag.hong { color: #ffb3a8; background: rgba(255,106,92,0.12); border-color: rgba(255,106,92,0.35); }
.sc-tag.diff { color: #ffe3a0; background: rgba(255,206,84,0.1); border-color: rgba(255,206,84,0.3); }
.sc-story { font-size: 30rpx; line-height: 2.1; margin-top: 20rpx; color: rgba(236,232,245,0.92); }
.sc-foot { margin-top: 24rpx; font-size: 20rpx; color: #9d8fbe; }

/* ── 汤底：杯垫 ── */
.coaster-zone { position: relative; margin-top: 8rpx; min-height: 200rpx; border-radius: 32rpx; overflow: hidden;
  border: 3rpx dashed rgba(77,184,255,0.35); }
.ans-text { position: absolute; left: 0; top: 0; right: 0; bottom: 0; padding: 28rpx 30rpx;
  font-size: 25rpx; line-height: 1.9; color: rgba(236,232,245,0.9);
  opacity: 0; filter: blur(14rpx); transition: all 0.3s; }
.coaster { position: absolute; left: 0; top: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10rpx;
  background: linear-gradient(165deg, #2a2244, #1e1836); transition: opacity 0.3s; }
.coaster .disc { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 38rpx; background: radial-gradient(circle at 36% 32%, #3d3260, #241d40);
  border: 3rpx solid rgba(160,200,255,0.3); }
.coaster .tp { font-size: 20rpx; color: #9d8fbe; letter-spacing: 2rpx; }
.coaster-zone.peek .coaster { opacity: 0; pointer-events: none; }
.coaster-zone.peek .ans-text { opacity: 1; filter: blur(0); }
.guest-lock { margin-top: 24rpx; padding: 32rpx; border-radius: 32rpx; text-align: center;
  font-size: 22rpx; color: #9d8fbe; background: rgba(255,255,255,0.055);
  border: 3rpx dashed rgba(255,255,255,0.13); line-height: 1.8; }

/* ── 分享按钮 ── */
.share-row { display: flex; gap: 20rpx; margin-top: 28rpx; }
.btn { flex: 1; height: 92rpx; display: flex; align-items: center; justify-content: center;
  border-radius: 999rpx; font-size: 27rpx; font-weight: 800; letter-spacing: 2rpx; color: #0e2438;
  background: linear-gradient(135deg, #7fd0ff, #4db8ff); box-shadow: 0 12rpx 36rpx rgba(77,184,255,0.3); }
.btn::after { border: none; }
.btn.ghost { background: rgba(255,255,255,0.05); color: #9d8fbe; box-shadow: none;
  border: 1rpx solid rgba(255,255,255,0.15); font-weight: 600; }
