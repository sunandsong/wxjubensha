<view class="container">

  <!-- ══ 大厅 ══ -->
  <block wx:if="{{mode === 'lobby'}}">
    <view class="title">谁是卧底 🎩</view>
    <view class="subtitle">相近的两个词，轮流描述找出卧底；卧底自己也不知道自己是卧底</view>

    <view class="card">
      <view class="sec-title">卧底人数</view>
      <view class="opts">
        <view class="opt {{spyCountSel === 1 ? 'on' : ''}}" data-n="1" bindtap="pickSpyCount">1 个卧底</view>
        <view class="opt {{spyCountSel === 2 ? 'on' : ''}}" data-n="2" bindtap="pickSpyCount">2 个卧底（6人+）</view>
      </view>
      <button class="btn" bindtap="createRoom">创建房间</button>
      <button class="btn btn-ghost" bindtap="showJoinModal">输入房间号加入</button>
    </view>

    <!-- 加入弹框 -->
    <view class="mask" wx:if="{{showJoin}}" bindtap="hideJoinModal">
      <view class="modal" catchtap="">
        <view class="m-title">加入房间</view>
        <input class="m-input" type="number" maxlength="4" placeholder="4 位房间号"
          value="{{joinInput}}" bindinput="onJoinInput" focus="{{showJoin}}" />
        <view class="m-btns">
          <button class="m-cancel" bindtap="hideJoinModal">取消</button>
          <button class="m-ok" bindtap="joinConfirm">进入</button>
        </view>
      </view>
    </view>
  </block>

  <!-- ══ 房间 ══ -->
  <block wx:if="{{mode === 'room'}}">
    <!-- 房间号卡 -->
    <view class="card">
      <view class="code-row">
        <view>
          <view class="muted">房间号</view>
          <view class="code">{{roomCode}}</view>
        </view>
        <view class="code-actions">
          <button class="btn-mini share" open-type="share">分享链接</button>
        </view>
      </view>
      <view class="muted invite-tip">
        {{status === 'waiting' ? '把链接发到群里，点开直接进房 · 满 4 人可开始' : ''}}
        {{status === 'playing' ? '游戏中 · 去群里轮流描述，口头投票' : ''}}
        {{status === 'finished' ? '本局已揭晓' : ''}}
      </view>
    </view>

    <!-- 玩家 -->
    <view class="card">
      <view class="row-between">
        <view class="sec-title">玩家（{{players.length}}）</view>
        <view class="muted" wx:if="{{status === 'waiting'}}">已准备 {{readyCount}}/{{needReady}}</view>
      </view>
      <view class="players">
        <view class="player" wx:for="{{players}}" wx:key="openid">
          <view class="host-badge" wx:if="{{item.isHost}}">房主</view>
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="pname">{{item.nick}}</view>
          <view class="ready-badge on" wx:if="{{status === 'waiting' && item.ready && !item.isHost}}">已准备</view>
          <view class="ready-badge spytag" wx:if="{{item.isSpy}}">卧底</view>
        </view>
      </view>
    </view>

    <!-- 等待阶段 -->
    <block wx:if="{{status === 'waiting'}}">
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="startGame" disabled="{{starting || !canStart}}">
        开始游戏（自动发词）
      </button>
      <view wx:if="{{isHost && !canStart}}" class="center muted ready-hint">
        {{players.length < 4 ? '满 4 人才能开始' : '等所有玩家点「准备好了」'}}
      </view>
      <button wx:if="{{!isHost}}" class="btn start-btn {{myReady ? 'btn-ghost' : ''}}" bindtap="toggleReady">
        {{myReady ? '已准备（点击取消）' : '准备好了'}}
      </button>
    </block>

    <!-- 游戏中：我的词卡 -->
    <block wx:if="{{status === 'playing'}}">
      <view class="card word-card">
        <view class="sec-title">我的词</view>
        <view class="wc-body">
          <view wx:if="{{peeking}}" class="wc-word">{{word}}</view>
          <view wx:if="{{!peeking}}" class="wc-cover"
            bindlongpress="peekOn" bindtouchend="peekOff" bindtouchcancel="peekOff">🔒 长按看词（松手盖回）</view>
          <view wx:if="{{peeking}}" class="wc-cover ghost"
            bindtouchend="peekOff" bindtouchcancel="peekOff"></view>
        </view>
        <view class="muted wc-tip">描述它，但别说出这个词；注意别暴露，卧底可能就是你自己</view>
      </view>
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="revealAll">揭晓（公布卧底）</button>
    </block>

    <!-- 已揭晓 -->
    <block wx:if="{{status === 'finished' && reveal}}">
      <view class="card">
        <view class="sec-title">真相</view>
        <view class="rev-row"><text class="muted">平民词</text><text class="rev-v">{{reveal.civilWord}}</text></view>
        <view class="rev-row"><text class="muted">卧底词</text><text class="rev-v warn">{{reveal.spyWord}}</text></view>
        <view class="rev-row"><text class="muted">卧底是</text><text class="rev-v warn">{{spyNicks}}</text></view>
        <view class="rev-me">{{iAmSpy ? '你就是卧底 🎭' : '你是平民 🙂'}}</view>
      </view>
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="playAgain">再来一局</button>
    </block>

    <button class="btn btn-ghost start-btn" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
  </block>
</view>
