<view class="container">
  <!-- ══ 大厅 ══ -->
  <block wx:if="{{mode === 'lobby'}}">
    <image class="lobby-hero" src="{{heroUrl || '/assets/games/th_spy_hero.png'}}" mode="aspectFit" binderror="onHeroErr"></image>
    <view class="title">谁是卧底 🎩</view>
    <view class="subtitle">相近的两个词，轮流描述找出卧底；卧底自己也不知道自己是卧底</view>

    <view class="resume-bar" wx:if="{{resumeId}}" bindtap="resumeRoom">
      🔔 你有一局还没结束 · 房间 {{resumeCode}}<text class="rb-go">回去 ›</text>
    </view>

    <view class="card">
      <view class="sec-title">卧底人数</view>
      <view class="opts">
        <view class="opt {{spyCountSel === 1 ? 'on' : ''}}" data-n="1" bindtap="pickSpyCount">1 个卧底</view>
        <view class="opt {{spyCountSel === 2 ? 'on' : ''}}" data-n="2" bindtap="pickSpyCount">2 个卧底（6人+）</view>
      </view>
      <button class="btn" bindtap="createRoom">创建房间</button>
      <button class="btn btn-ghost" bindtap="showJoinModal">输入房间号加入</button>
    </view>

  </block>

  <!-- 加入弹框 -->
  <view class="mask" wx:if="{{showJoin}}" bindtap="hideJoinModal">
    <view class="modal" catchtap="">
      <view class="m-title">加入房间</view>
      <input class="m-input" type="number" maxlength="4" placeholder="4 位房间号"
        value="{{joinInput}}" bindinput="onJoinInput" focus="{{showJoin}}" />
      <view class="m-tip">输满 4 位自动进入</view>
      <view class="m-btns">
        <button class="m-cancel" bindtap="hideJoinModal">取消</button>
      </view>
    </view>
  </view>

  <!-- 投票弹框 -->
  <view class="mask" wx:if="{{showVote}}" bindtap="hideVoteSheet">
    <view class="modal" catchtap="">
      <view class="m-title">投出你心中的卧底</view>
      <view class="vt-list">
        <view class="vt-item {{item.openid === myVote ? 'picked' : ''}}"
          wx:for="{{voteTargets}}" wx:key="openid"
          data-openid="{{item.openid}}" data-nick="{{item.nick}}" bindtap="voteFor">
          <view class="vt-avatar">
            <image wx:if="{{item.avatar}}" class="vt-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="vt-nick">{{item.nick}}</view>
          <view class="vt-check" wx:if="{{item.openid === myVote}}">✓ 我投的</view>
        </view>
      </view>
      <view class="m-btns">
        <button class="m-cancel" bindtap="hideVoteSheet">关闭</button>
      </view>
    </view>
  </view>

  <!-- ══ 房间 ══ -->
  <block wx:if="{{mode === 'room'}}">
    <!-- 等待：游戏名 + 房间号大字 + 玩家网格（对齐剧本杀） -->
    <block wx:if="{{status === 'waiting'}}">
      <view class="rm-script">谁是卧底 🎩</view>
      <view class="codebox">
        <view class="code-lab">房 间 号</view>
        <view class="code-big">{{roomCode}}</view>
      </view>
      <view class="rm-narr">人齐了，揪出隐藏的卧底</view>

      <view class="rm-players">
        <view class="player" wx:for="{{players}}" wx:key="openid">
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
            <view class="okmark" wx:if="{{item.ready && !item.isHost}}">✓</view>
          </view>
          <view class="host-badge" wx:if="{{item.isHost}}">房主</view>
          <view class="pname">{{item.nick}}</view>
        </view>
        <view class="player" wx:for="{{emptySlots}}" wx:key="*this">
          <view class="avatar slot-empty">?</view>
          <view class="pname pname-dim">等待中</view>
        </view>
      </view>

      <button wx:if="{{isHost}}" hover-class="none" class="btn start-btn {{(starting || !canStart) ? 'btn-dim' : ''}}" bindtap="startGame" disabled="{{starting || !canStart}}">开始游戏</button>
      <view wx:if="{{isHost && !canStart}}" class="center muted rm-count">{{players.length < 4 ? '满 4 人才能开始' : '等所有玩家点「准备好了」'}}</view>
      <button wx:if="{{!isHost}}" hover-class="none" class="btn start-btn {{myReady ? 'btn-ghost' : ''}}" bindtap="toggleReady">{{myReady ? '已准备（点击取消）' : '准备好了'}}</button>
      <button hover-class="none" class="btn btn-ghost" open-type="share">分享链接 · 邀请群友</button>
      <button hover-class="none" class="btn btn-ghost btn-slim" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
    </block>

    <!-- 游戏中 / 已揭晓（对齐设计稿：标题 + 旁白 + 机密卡 + 玩家卡） -->
    <block wx:if="{{status !== 'waiting'}}">

    <!-- 游戏中 -->
    <block wx:if="{{status === 'playing'}}">
      <view class="pg-title" wx:if="{{!isHost}}">第 {{round}} 轮</view>
      <view class="pg-narr" wx:if="{{!isHost}}">有一个人，拿到的词不一样</view>

      <!-- 房主主持词：含每轮随机描述顺序，复制发群 -->
      <view class="card host-script-card" wx:if="{{isHost && hostScript}}">
        <view class="host-script">{{hostScript}}</view>
        <view class="copy-link" bindtap="copyHostScript">📋 复制主持词发到群里</view>
      </view>

      <!-- 词卡：机密卡背，点击翻开（同狼人杀身份牌） -->
      <view class="idcard {{peeking ? 'open' : ''}}" bindtap="toggleWordCard">
        <view class="card-inner">
          <view class="id-face id-back">
            <image class="face-img" src="{{cardUrl || '/assets/games/th_spy_card.jpg'}}" mode="aspectFill" binderror="onCardErr"></image>
          </view>
          <view class="id-face id-front">
            <image class="face-img" src="{{cardFrontUrl || '/assets/games/th_spy_card_front.jpg'}}" mode="aspectFill" binderror="onCardFrontErr"></image>
            <view class="wd-inner">
              <view class="wd-label">你 的 词</view>
              <view class="wd-word" style="font-size:{{wdSize}}rpx">{{word}}</view>
            </view>
          </view>
        </view>
        <view class="id-hint {{peeking ? 'on-light' : ''}}">{{peeking ? '点击盖回' : '点击翻开 · 看完记得盖回'}}</view>
      </view>
      <view class="muted wc-tip">描述它，但别说出这个词；卧底可能就是你自己</view>

      <!-- 上一轮结果公告 -->
      <view class="card vote-ann" wx:if="{{lastVoteText}}">{{lastVoteText}}</view>

      <!-- 玩家：标出房主、出局、投票进度 -->
      <view class="card">
        <view class="row-between">
          <view class="sec-title">玩家（{{players.length}}）</view>
          <view class="muted" wx:if="{{voting}}">已投 {{votedCount}}/{{aliveCount}}</view>
        </view>
        <view class="players">
          <view class="player {{item.out ? 'out' : ''}}" wx:for="{{players}}" wx:key="openid">
            <view class="host-badge" wx:if="{{item.isHost}}">房主</view>
            <view class="avatar">
              <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
              <block wx:else>{{item.nick[0]}}</block>
            </view>
            <view class="out-stamp" wx:if="{{item.out}}">OUT</view>
            <view class="pname">{{item.nick}}</view>
            <view class="votedmark" wx:if="{{!item.out && voting && item.voted}}">✓</view>
          </view>
        </view>
      </view>

      <!-- 投票状态区：房主开启投票，弹框里选人 -->
      <block wx:if="{{!voting}}">
        <button wx:if="{{isHost}}" hover-class="none" class="btn start-btn" bindtap="openVoteStart">开启投票</button>
        <view wx:else class="muted center rm-count">描述完等房主开启投票</view>
      </block>
      <block wx:else>
        <button wx:if="{{!myOut}}" hover-class="none" class="btn start-btn {{myVote ? 'btn-ghost' : ''}}" bindtap="showVoteSheet">
          {{myVote ? '已投给 ' + myVoteNick + ' · 点击改票' : '🗳 去投票'}}
        </button>
        <view wx:if="{{myOut}}" class="muted center rm-count">👻 你已出局，等大家投完</view>
        <!-- 房主：投满后公布本轮结果（不再自动出结果） -->
        <button wx:if="{{isHost}}" hover-class="none" class="btn start-btn {{votedCount < aliveCount ? 'btn-dim' : ''}}" bindtap="revealRound">
          {{votedCount < aliveCount ? '等待投票（' + votedCount + '/' + aliveCount + '）' : '📢 公布本轮结果'}}
        </button>
      </block>
    </block>

    <!-- 已揭晓 -->
    <block wx:if="{{status === 'finished' && reveal}}">
      <view class="card">
        <view class="win-line" wx:if="{{reveal.winner}}">{{reveal.winner === 'spy' ? '卧底获胜 🎭' : '平民获胜 🎉'}}</view>
        <view class="sec-title">真相</view>
        <view class="rev-row"><text class="muted">平民词</text><text class="rev-v">{{reveal.civilWord}}</text></view>
        <view class="rev-row"><text class="muted">卧底词</text><text class="rev-v warn">{{reveal.spyWord}}</text></view>
        <view class="rev-row"><text class="muted">卧底是</text><text class="rev-v warn">{{spyNicks}}</text></view>
        <view class="rev-me">{{iAmSpy ? '你就是卧底 🎭' : '你是平民 🙂'}}</view>
      </view>
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="playAgain">再来一局</button>
    </block>

    <button hover-class="none" class="btn btn-ghost btn-slim" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
    </block>
  </block>
</view>

<id-switch />
