/* 谁是卧底 —— 复用全局暗夜悬疑风（app.wxss），此处只补页面特有部分 */

/* 页面主题色：粉色（对齐 hub 卡片的 #ff5c8a），覆盖全局紫色按钮。
   注意：页面样式在 app.wxss 之后加载，覆盖 .btn 会连带盖掉 .btn-ghost 的透明背景，
   所以幽灵态必须在这里跟着重新声明一遍。 */
.btn {
  background: linear-gradient(90deg, #ff4d7e, #ff85a8);
}
.btn-ghost {
  background: transparent;
}
.btn[disabled] {
  background: linear-gradient(90deg, #ff4d7e, #ff85a8) !important;
}
.btn-ghost[disabled] {
  background: transparent !important;
}

/* 房间号（对齐 room 页） */
.code-row { display: flex; align-items: center; justify-content: space-between; }
.code { font-size: 56rpx; font-weight: 700; letter-spacing: 12rpx; color: #fff; margin-top: 8rpx; }
.btn-mini {
  background: rgba(123,92,255,0.3); color: #ddd2ff; font-size: 26rpx;
  padding: 12rpx 28rpx; border-radius: 999rpx; line-height: 1.6;
}
.btn-mini::after { border: none; }
.btn-mini.share { background: linear-gradient(90deg, #ff4d7e, #ff85a8); color: #fff; }
.code-actions { display: flex; gap: 14rpx; align-items: center; }
.invite-tip { margin-top: 18rpx; }

.row-between { display: flex; align-items: center; justify-content: space-between; }
.sec-title { font-size: 30rpx; font-weight: 600; }

/* 玩家网格（对齐 room 页） */
.players { display: flex; flex-wrap: wrap; gap: 24rpx; margin-top: 24rpx; }
.player { position: relative; width: 120rpx; text-align: center; }
.avatar {
  width: 96rpx; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  border-radius: 50%; font-size: 40rpx; color: #fff; overflow: hidden;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
}
.avatar .avatar-img { width: 96rpx; height: 96rpx; display: block; }
.pname { font-size: 24rpx; margin-top: 10rpx; color: #ddd6ee; line-height: 1.3; word-break: break-all; }
.host-badge {
  position: absolute; top: -8rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; white-space: nowrap; z-index: 1;
  background: #ffb347; color: #3a2a00; border-radius: 999rpx; padding: 2rpx 10rpx;
}
.ready-badge {
  margin-top: 8rpx; font-size: 18rpx; white-space: nowrap;
  display: inline-block; padding: 2rpx 12rpx; border-radius: 999rpx;
  color: #b3a6cc; background: rgba(255,255,255,0.08);
}
.ready-badge.on { color: #1c3b22; background: #7fe0a8; }
.ready-badge.spytag { color: #fff; background: linear-gradient(90deg, #ff5c7a, #c44dff); }
.ready-hint { margin-top: 14rpx; }
.center { text-align: center; }
.warn { color: #ffb347; }

.btn { width: 100% !important; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.start-btn { margin-top: 32rpx; padding: 44rpx 0; font-size: 36rpx; }

/* 卧底人数选项 */
.opts { display: flex; gap: 18rpx; margin-top: 22rpx; }
.opt {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: 16rpx; font-size: 27rpx;
  color: #b3a6cc; background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.12);
}
.opt.on {
  color: #fff; font-weight: 600; border-color: transparent;
  background: linear-gradient(90deg, #ff4d7e, #ff85a8);
}

/* 加入弹框（对齐进入房间弹框风格） */
.mask { position: fixed; inset: 0; z-index: 30; display: flex; align-items: center; justify-content: center;
  background: rgba(10,6,20,0.75); }
.modal { width: 78%; padding: 44rpx 36rpx; border-radius: 24rpx;
  background: #2a2140; border: 1rpx solid rgba(255,255,255,0.12); }
.m-title { font-size: 34rpx; font-weight: 700; color: #ece8f5; text-align: center; }
.m-input { margin: 30rpx auto 0; height: 96rpx; border-radius: 16rpx; font-size: 40rpx; letter-spacing: 12rpx;
  text-align: center; color: #fff; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.16); }
.m-tip { margin-top: 16rpx; text-align: center; font-size: 24rpx; color: #b3a6cc; }
.m-btns { margin-top: 26rpx; display: flex; gap: 20rpx; }
.m-cancel, .m-ok { flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center; margin: 0;
  border-radius: 16rpx; font-size: 29rpx; font-weight: 600; }
.m-cancel { color: #d9d2ec; background: transparent; border: 1rpx solid rgba(255,255,255,0.25); }
.m-ok { color: #fff; background: linear-gradient(90deg, #ff4d7e, #ff85a8); }
.m-cancel::after, .m-ok::after { border: none; }

/* 词卡 */
.word-card { text-align: center; }
.word-card .sec-title { text-align: left; }
.wc-body { position: relative; margin-top: 22rpx; min-height: 120rpx; }
.wc-word { font-size: 76rpx; font-weight: 700; color: #fff; letter-spacing: 6rpx; line-height: 120rpx;
  text-shadow: 0 4rpx 20rpx rgba(150,92,255,0.45); }
.wc-cover { padding: 34rpx 0; border-radius: 16rpx; font-size: 26rpx; color: #b3a6cc;
  background: rgba(0,0,0,0.25); border: 1rpx dashed rgba(255,255,255,0.2); }
.wc-cover.ghost { position: absolute; inset: 0; z-index: 5; opacity: 0; padding: 0; border: none; }
.wc-tip { margin-top: 20rpx; text-align: left; font-size: 22rpx; line-height: 1.6; }

/* 揭晓 */
.rev-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.rev-v { font-size: 34rpx; font-weight: 700; color: #fff; }
.rev-me { margin-top: 20rpx; padding-top: 24rpx; border-top: 1rpx dashed rgba(255,255,255,0.15);
  font-size: 28rpx; font-weight: 600; color: #ffb347; text-align: center; }

/* 未结束对局的回去横幅（大厅顶部） */
.resume-bar {
  display: flex; align-items: center; margin: 0 0 20rpx; padding: 20rpx 26rpx;
  border-radius: 20rpx; font-size: 26rpx; color: #ffe3a0;
  background: rgba(255,206,84,0.1); border: 1rpx solid rgba(255,206,84,0.32);
}
.rb-go { margin-left: auto; font-weight: 700; color: #ffce54; }

/* ── 聚光灯审讯室底图 + 内容区暗纱 ── */
.scene-bg { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0;
  opacity: 0; transition: opacity 0.6s ease; }
.scene-bg.on { opacity: 0.2; }
.scene-fade { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none;
  background: linear-gradient(180deg, rgba(30,24,48,0) 0%, rgba(30,24,48,0.4) 34%, rgba(30,24,48,0.8) 60%, rgba(30,24,48,0.9) 100%); }
/* 内容抬到底图/暗纱之上（WXSS 子选择器不可靠,显式列类名） */
.title, .subtitle, .resume-bar, .card, .btn, .center, .ready-hint,
.secret-card, .lobby-hero, .dev-upload, .wc-tip { position: relative; z-index: 1; }

/* ── 大厅立绘：礼帽面具 ── */
.lobby-hero { display: block; width: 300rpx; height: 300rpx; margin: 0 auto -10rpx;
  filter: drop-shadow(0 14rpx 30rpx rgba(0,0,0,0.5)); }

/* ── 机密卡：档案卡面 + 按住显影 ── */
.secret-card { position: relative; margin-top: 20rpx; border-radius: 24rpx; overflow: hidden;
  min-height: 300rpx; border: 1rpx solid rgba(255,255,255,0.18);
  background: linear-gradient(160deg, #2c2244, #221936);
  box-shadow: 0 16rpx 44rpx rgba(0,0,0,0.5); }
.sc-face { position: absolute; left: 0; top: 0; width: 100%; height: 100%; }
.sc-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; }
.sc-label { font-size: 20rpx; letter-spacing: 8rpx; color: rgba(236,232,245,0.65); }
.sc-word { font-size: 76rpx; font-weight: 900; letter-spacing: 10rpx; margin-top: 26rpx; line-height: 1.2;
  color: transparent; text-shadow: 0 0 30rpx rgba(236,232,245,0.85); transition: all 0.4s; }
.secret-card.open .sc-word { color: #fff; text-shadow: 0 0 36rpx rgba(255,92,138,0.55); }
.sc-tip { margin-top: 30rpx; font-size: 20rpx; letter-spacing: 2rpx; color: rgba(236,232,245,0.55); }

/* 一次性上传按钮（跑完删除） */
.dev-upload { margin: 40rpx auto 0; width: 80%; font-size: 26rpx; color: #fff;
  background: rgba(255,255,255,0.14); border: 1rpx solid rgba(255,255,255,0.3); border-radius: 999rpx; }

/* ══ 等待房间：布局对齐剧本杀 ══ */
.rm-script { text-align: center; font-size: 44rpx; font-weight: 700; color: #fff; margin-top: 12rpx; letter-spacing: 4rpx; position: relative; }
.codebox { text-align: center; margin: 34rpx 0 4rpx; position: relative; }
.code-lab { font-size: 22rpx; letter-spacing: 10rpx; color: #8a7fa6; }
.code-big {
  font-size: 140rpx; font-weight: 900; letter-spacing: 30rpx; color: #fff; line-height: 1.35;
  text-shadow: 0 0 50rpx rgba(140, 100, 255, 0.45);
}
.rm-narr { text-align: center; font-size: 25rpx; color: #b3a6cc; margin-bottom: 26rpx; position: relative; }

.rm-players { display: flex; flex-wrap: wrap; justify-content: center; gap: 28rpx 30rpx; margin: 8rpx 0 4rpx; position: relative; }
.rm-players .avatar { position: relative; overflow: visible; }
.rm-players .avatar .avatar-img { border-radius: 50%; }
.okmark {
  position: absolute; right: -6rpx; top: -6rpx; z-index: 2;
  width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center;
  border-radius: 50%; font-size: 22rpx; color: #fff;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
  border: 2rpx solid #1e1830;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.45);
}
.avatar.slot-empty {
  background: none; border: 2rpx dashed rgba(255, 255, 255, 0.25);
  color: #8a7fa6; font-size: 34rpx; box-sizing: border-box;
}
.pname-dim { color: #8a7fa6; }
.rm-count { margin-top: 20rpx; position: relative; }
