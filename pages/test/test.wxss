.hero { padding: 48rpx 8rpx 8rpx; text-align: center; }
.title { font-size: 48rpx; font-weight: 700; }
.t-sub { font-size: 26rpx; color: #b3a6cc; margin-top: 16rpx; line-height: 1.6; }

.t-list { margin-top: 40rpx; display: flex; flex-direction: column; gap: 24rpx; }
.t-item {
  display: flex; align-items: center; gap: 24rpx;
  background: rgba(255,255,255,0.06); border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 20rpx; padding: 28rpx 30rpx;
}
.t-item.on { border-color: #c44dff; background: rgba(196,77,255,0.12); }
.t-avatar {
  width: 88rpx; height: 88rpx; line-height: 88rpx; text-align: center;
  border-radius: 50%; color: #fff; font-size: 38rpx; font-weight: 600;
  background: linear-gradient(135deg, #7b5cff, #c44dff);
}
.t-name { flex: 1; font-size: 34rpx; font-weight: 600; color: #fff; }
.t-cur { font-size: 24rpx; color: #c44dff; }

.t-tip { margin-top: 32rpx; font-size: 24rpx; color: #8a7da6; line-height: 1.6; }
