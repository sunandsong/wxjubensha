<view class="container">
  <!-- 昼夜森林底图：同一片松林,天亮交叉淡入清晨版 -->
  <image wx:if="{{bgN}}" class="scene-bg {{(mode !== 'room' || status !== 'day') ? 'on' : ''}}" src="{{bgN}}" mode="aspectFill"></image>
  <image wx:if="{{bgD}}" class="scene-bg bg-day {{mode === 'room' && status === 'day' ? 'on' : ''}}" src="{{bgD}}" mode="aspectFill"></image>
  <view class="scene-fade"></view>

  <!-- ══ 大厅 ══ -->
  <block wx:if="{{mode === 'lobby'}}">
    <view class="title">狼人杀 🐺</view>
    <view class="subtitle">6–12 名玩家 + 上帝主持：夜晚玩家在这里行动，白天上帝带群里讨论投票</view>

    <view class="resume-bar" wx:if="{{resumeId}}" bindtap="resumeRoom">
      🔔 你有一局还没结束 · 房间 {{resumeCode}}<text class="rb-go">回去 ›</text>
    </view>

    <view class="card">
      <view class="sec-title">板子（按人数自动配置）</view>
      <view class="board-line">6–9 人：2 狼人 + 预言家 + 女巫 + 平民</view>
      <view class="board-line">10–12 人：3 狼人 + 预言家 + 女巫 + 平民</view>
      <view class="board-line muted">上帝（房主）不发身份、不计入人数；夜晚各角色行动云端自动结算，白天上帝执行出局</view>
      <button class="btn" bindtap="createRoom">创建房间</button>
      <button class="btn btn-ghost" bindtap="showJoinModal">输入房间号加入</button>
    </view>
  </block>

  <!-- 加入弹框 -->
  <view class="mask" wx:if="{{showJoin}}" bindtap="hideJoinModal">
    <view class="modal" catchtap="">
      <view class="m-title">加入房间</view>
      <input class="m-input" type="number" maxlength="4" placeholder="4 位房间号"
        value="{{joinInput}}" bindinput="onJoinInput" focus="{{showJoin}}" />
      <view class="m-tip">输满 4 位自动进入</view>
      <view class="m-btns">
        <button class="m-cancel" bindtap="hideJoinModal">取消</button>
      </view>
    </view>
  </view>

  <!-- ══ 房间 ══ -->
  <block wx:if="{{mode === 'room'}}">
    <!-- 房间号卡 -->
    <view class="card">
      <view class="code-row">
        <view>
          <view class="muted">房间号</view>
          <view class="code">{{roomCode}}</view>
        </view>
        <view class="code-actions">
          <button class="btn-mini share" open-type="share">分享链接</button>
        </view>
      </view>
      <view class="muted invite-tip" wx:if="{{status === 'waiting'}}">把链接发到群里，点开直接进房 · 满 6 名玩家可开始（上帝不算）</view>
    </view>

    <!-- 阶段卡：白天/黑夜大字 + 黑夜行动说明 -->
    <view class="card phase-card {{status === 'day' ? 'p-day' : ''}}" wx:if="{{status !== 'waiting'}}">
      <view class="ph-big">{{status === 'night' ? '🌙 第 ' + round + ' 夜 · 天黑请闭眼' : status === 'day' ? '☀️ 第 ' + round + ' 天 · 天亮请睁眼' : '🃏 终局 · 请亮牌'}}</view>
      <view class="ph-sub" wx:if="{{status === 'night'}}">现在行动：🐺 狼人选目标 · 🔮 预言家验人 · 🧪 女巫用药</view>
      <view class="ph-sub2" wx:if="{{status === 'night'}}">三方都完成后自动天亮 · 平民请闭眼等待</view>
      <view class="ph-sub" wx:if="{{status === 'day'}}">回群里讨论发言 · 口头投票后由上帝执行放逐</view>
    </view>

    <!-- 公告：死讯/出局 -->
    <view class="card announce" wx:if="{{announceText && status !== 'waiting'}}">{{announceText}}</view>

    <!-- 上帝视角：全员身份 + 夜晚进度（只有房主可见） -->
    <view class="card god-card" wx:if="{{isHost && status !== 'waiting' && god}}">
      <view class="sec-title">👁️ 上帝视角（只有你能看到）</view>
      <view class="god-row" wx:for="{{god.list}}" wx:key="nick">
        <text class="g-nick {{item.out ? 'gout' : ''}}">{{item.nick}}{{item.out ? '（出局）' : ''}}</text>
        <text class="g-role {{item.role}}">{{item.roleName}}</text>
      </view>
      <view class="god-night" wx:if="{{god.night}}">
        🌙 狼人{{god.night.wolfDone ? (god.night.kill ? ' 已刀 ' + god.night.kill : ' 空刀') : ' 行动中…'}} · 预言家{{god.night.seerDone ? ' ✓' : ' …'}} · 女巫{{god.night.witchDone ? ' ✓' : ' …'}}{{god.night.saved ? ' · 已用解药' : ''}}{{god.night.poison ? ' · 毒了 ' + god.night.poison : ''}}
      </view>
      <view class="god-night">🧪 解药{{god.potions.save ? '还在' : '已用'}} · 毒药{{god.potions.poison ? '还在' : '已用'}}</view>
    </view>

    <!-- 我的身份卡（玩家）：图腾卡背,长按翻开角色牌 -->
    <view class="card word-card" wx:if="{{status !== 'waiting' && !isHost}}">
      <view class="sec-title">我的身份{{myOut ? '（已出局 👻）' : ''}}</view>
      <view class="idcard {{peeking ? 'open' : ''}}"
        bindlongpress="peekOn" bindtouchend="peekOff" bindtouchcancel="peekOff">
        <image wx:if="{{backUrl}}" class="id-face id-back" src="{{backUrl}}" mode="aspectFill"></image>
        <view wx:else class="id-face id-back id-back-css">🐺</view>
        <image wx:if="{{roleImg}}" class="id-face id-front" src="{{roleImg}}" mode="aspectFill"></image>
        <view wx:else class="id-face id-front id-front-css">{{roleName}}</view>
        <view class="id-name" wx:if="{{peeking}}">{{roleName}}</view>
        <view class="id-hint" wx:if="{{!peeking}}">🔒 长按看身份 · 松手盖回</view>
      </view>
      <view class="mates" wx:if="{{peeking && matesText}}">狼队友：{{matesText}}</view>
    </view>

    <!-- 玩家（夜晚/白天点头像行动） -->
    <view class="card">
      <view class="row-between">
        <view class="sec-title">玩家（{{players.length}}）</view>
        <view class="muted" wx:if="{{status === 'waiting'}}">已准备 {{readyCount}}/{{needReady}}</view>
      </view>
      <view class="act-tip" wx:if="{{actTip}}">{{actTip}}</view>
      <view class="players">
        <view class="player {{item.out ? 'out' : ''}} {{item.openid === myTarget ? 'picked' : ''}}"
          wx:for="{{players}}" wx:key="openid"
          data-openid="{{item.openid}}" data-nick="{{item.nick}}" data-out="{{item.out}}"
          bindtap="onPlayerTap">
          <view class="host-badge" wx:if="{{item.isHost}}">上帝</view>
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="pname">{{item.nick}}</view>
          <view class="ready-badge on" wx:if="{{status === 'waiting' && item.ready && !item.isHost}}">已准备</view>
          <view class="tomb" wx:if="{{item.out}}">🪦</view>
        </view>
      </view>
    </view>

    <!-- 等待阶段 -->
    <block wx:if="{{status === 'waiting'}}">
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="startGame" disabled="{{starting || !canStart}}">
        开始游戏（自动发身份）
      </button>
      <view wx:if="{{isHost && !canStart}}" class="center muted ready-hint">
        {{needReady < 6 ? '满 6 名玩家才能开始（上帝不算，还差 ' + (6 - needReady) + ' 人）' : '等所有玩家点「准备好了」'}}
      </view>
      <button wx:if="{{!isHost}}" class="btn start-btn {{myReady ? 'btn-ghost' : ''}}" bindtap="toggleReady">
        {{myReady ? '已准备（点击取消）' : '准备好了'}}
      </button>
    </block>

    <!-- 夜晚：角色面板 -->
    <block wx:if="{{status === 'night' && !myOut && night}}">
      <!-- 狼人频道 -->
      <view class="card" wx:if="{{role === 'wolf'}}">
        <view class="sec-title">狼人频道 🐺</view>
        <view class="board-line" wx:for="{{night.votes}}" wx:key="nick">{{item.nick}} → {{item.target || '还没选'}}</view>
        <view class="muted night-wait" wx:if="{{night.done}}">刀口已定{{night.kill ? '：' + night.kill : '（空刀）'}}，等待天亮…</view>
      </view>

      <!-- 预言家 -->
      <view class="card" wx:if="{{role === 'seer'}}">
        <view class="sec-title">查验记录 🔮</view>
        <view class="board-line" wx:for="{{night.history}}" wx:key="round">
          第 {{item.round}} 夜：{{item.nick}} — {{item.isWolf ? '狼人 🐺' : '好人 🙂'}}
        </view>
        <view class="muted night-wait" wx:if="{{night.done}}">今晚已查验，等待天亮…</view>
      </view>

      <!-- 女巫 -->
      <view class="card" wx:if="{{role === 'witch'}}">
        <view class="sec-title">女巫的药 🧪</view>
        <block wx:if="{{!night.unlocked}}">
          <view class="muted night-wait">狼人还没动手，稍等…</view>
        </block>
        <block wx:elif="{{!night.done}}">
          <view class="board-line">{{night.killId ? '☠️ 今晚「' + night.killNick + '」被刀' : '今晚是空刀，无人被害'}}</view>
          <button class="btn witch-btn" wx:if="{{night.canSave}}" bindtap="witchSave">💊 用解药救 {{night.killNick}}</button>
          <button class="btn btn-ghost witch-btn" wx:if="{{night.canPoison}}" bindtap="witchPoisonToggle">
            {{pickPoison ? '取消用毒' : '☠️ 用毒药（点上方头像选人）'}}
          </button>
          <button class="btn btn-ghost witch-btn" bindtap="witchSkip">🌙 不用药</button>
        </block>
        <view class="muted night-wait" wx:else>今晚已行动，等待天亮…</view>
      </view>

      <!-- 平民 -->
      <view class="card" wx:if="{{role === 'villager'}}">
        <view class="muted center night-wait">🌙 夜深了，闭眼睡觉，等待天亮…</view>
      </view>
    </block>

    <!-- 出局的人 -->
    <view class="card" wx:if="{{status !== 'waiting' && status !== 'finished' && myOut}}">
      <view class="muted center night-wait">👻 你已出局，安静吃瓜，等本局结束</view>
    </view>

    <!-- 白天：非房主提示 -->
    <view class="card" wx:if="{{status === 'day' && !isHost && !myOut}}">
      <view class="muted center night-wait">☀️ 回群里发言讨论，口头投票后由房主执行出局</view>
    </view>

    <!-- 已结束：身份公开 -->
    <block wx:if="{{status === 'finished' && reveal}}">
      <view class="card">
        <view class="win-line">{{winnerText}}</view>
        <view class="rev-narr">请亮牌——</view>
        <view class="rev-cards">
          <view class="rev-card {{item.role === 'wolf' ? 'is-wolf' : ''}}"
            wx:for="{{reveal.roles}}" wx:key="openid" style="animation-delay:{{index * 220}}ms">
            <view class="rc-role">{{item.roleName}}</view>
            <view class="rc-nick">{{item.nick}}</view>
          </view>
        </view>
      </view>
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="playAgain">再来一局</button>
    </block>

    <!-- 房主控制 -->
    <button wx:if="{{isHost && status === 'night'}}" class="btn btn-ghost start-btn" bindtap="forceDawn">强制天亮（跳过未行动）</button>
    <button wx:if="{{isHost && (status === 'night' || status === 'day')}}" class="btn btn-ghost start-btn" bindtap="revealAll">提前揭晓（结束本局）</button>

    <button class="btn btn-ghost start-btn" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
  </block>

  <!-- 一次性：程序内上传牌面素材（成功后删除本按钮） -->
  <button class="dev-upload" wx:if="{{mode === 'lobby'}}" bindtap="uploadWolfAssets">↑ 上传狼人杀牌面（一次性）</button>
</view>

<id-switch />
