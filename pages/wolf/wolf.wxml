<view class="container">
  <!-- 昼夜森林底图：同一片松林,天亮交叉淡入清晨版 -->
  <!-- 背景只在开局后(夜/昼/终局)显示;大厅与等待界面无背景 -->
  <image wx:if="{{mode === 'room' && status !== 'waiting' && bgN}}" class="scene-bg {{status !== 'day' ? 'on' : ''}}" src="{{bgN}}" mode="aspectFill"></image>
  <image wx:if="{{mode === 'room' && status !== 'waiting' && bgD}}" class="scene-bg bg-day {{status === 'day' ? 'on' : ''}}" src="{{bgD}}" mode="aspectFill"></image>
  <view class="scene-fade" wx:if="{{mode === 'room' && status !== 'waiting'}}"></view>

  <!-- ══ 大厅 ══ -->
  <block wx:if="{{mode === 'lobby'}}">
    <view class="title">狼人杀 🐺</view>
    <view class="subtitle">6–12 名玩家 + 上帝主持：夜晚玩家在这里行动，白天上帝带群里讨论投票</view>

    <view class="resume-bar" wx:if="{{resumeId}}" bindtap="resumeRoom">
      🔔 你有一局还没结束 · 房间 {{resumeCode}}<text class="rb-go">回去 ›</text>
    </view>

    <view class="card">
      <view class="sec-title">板子（按人数自动配置）</view>
      <view class="board-line">6–9 人：2 狼人 + 预言家 + 女巫 + 平民</view>
      <view class="board-line">10–12 人：3 狼人 + 预言家 + 女巫 + 平民</view>
      <view class="board-line muted">上帝（房主）不发身份、不计入人数；夜晚各角色行动云端自动结算，白天上帝执行出局</view>
      <button class="btn" bindtap="createRoom">创建房间</button>
      <button class="btn btn-ghost" bindtap="showJoinModal">输入房间号加入</button>
    </view>
  </block>

  <!-- 加入弹框 -->
  <view class="mask" wx:if="{{showJoin}}" bindtap="hideJoinModal">
    <view class="modal" catchtap="">
      <view class="m-title">加入房间</view>
      <input class="m-input" type="number" maxlength="4" placeholder="4 位房间号"
        value="{{joinInput}}" bindinput="onJoinInput" focus="{{showJoin}}" />
      <view class="m-tip">输满 4 位自动进入</view>
      <view class="m-btns">
        <button class="m-cancel" bindtap="hideJoinModal">取消</button>
      </view>
    </view>
  </view>

  <!-- ══ 房间 ══ -->
  <block wx:if="{{mode === 'room'}}">
    <!-- 等待：游戏名 + 房间号大字 + 玩家网格（对齐剧本杀） -->
    <block wx:if="{{status === 'waiting'}}">
      <view class="rm-script">狼人杀 🐺</view>
      <view class="codebox">
        <view class="code-lab">房 间 号</view>
        <view class="code-big">{{roomCode}}</view>
      </view>
      <view class="rm-narr">人齐了，天黑请闭眼</view>

      <view class="rm-players">
        <view class="player" wx:for="{{players}}" wx:key="openid">
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
            <view class="okmark" wx:if="{{item.ready && !item.isHost}}">✓</view>
          </view>
          <view class="host-badge" wx:if="{{item.isHost}}">上帝</view>
          <view class="pname">{{item.nick}}</view>
        </view>
        <view class="player" wx:for="{{emptySlots}}" wx:key="*this">
          <view class="avatar slot-empty">?</view>
          <view class="pname pname-dim">等待中</view>
        </view>
      </view>

      <button wx:if="{{isHost}}" hover-class="none" class="btn start-btn {{(starting || !canStart) ? 'btn-dim' : ''}}" bindtap="startGame" disabled="{{starting || !canStart}}">开始游戏</button>
      <view wx:if="{{isHost && !canStart}}" class="center muted rm-count">{{needReady < 6 ? '还差 ' + (6 - needReady) + ' 名玩家 · 上帝不占身份' : '等所有玩家点「准备好了」'}}</view>
      <button wx:if="{{!isHost}}" hover-class="none" class="btn start-btn {{myReady ? 'btn-ghost' : ''}}" bindtap="toggleReady">{{myReady ? '已准备（点击取消）' : '准备好了'}}</button>
      <button hover-class="none" class="btn btn-ghost" open-type="share">分享链接 · 邀请群友</button>
      <button hover-class="none" class="btn btn-ghost" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
    </block>

    <!-- 阶段卡：白天/黑夜大字 + 黑夜行动说明 -->
    <view class="card phase-card {{status === 'day' ? 'p-day' : ''}}" wx:if="{{status !== 'waiting'}}">
      <view class="ph-big">{{status === 'night' ? '🌙 第 ' + round + ' 夜 · 天黑请闭眼' : status === 'day' ? '☀️ 第 ' + round + ' 天 · 天亮请睁眼' : '🃏 终局 · 请亮牌'}}</view>
      <!-- 上帝:主持词全文(点复制发群) -->
      <block wx:if="{{isHost && hostScript}}">
        <view class="ph-script">{{hostScript}}</view>
        <text class="mini-btn ph-copy" bindtap="copyHostScript">📋 复制主持词</text>
      </block>
      <!-- 玩家:简短说明 -->
      <block wx:else>
        <view class="ph-sub" wx:if="{{status === 'night'}}">天黑请闭眼 · 对应角色在小程序里悄悄行动</view>
        <view class="ph-sub" wx:if="{{status === 'day'}}">讨论发言 · 点你要放逐的人投票（可改票）</view>
      </block>
    </view>


    <!-- 玩家白天：投票按钮（点开弹框选人,对齐卧底/剧本杀） -->
    <button wx:if="{{!isHost && status === 'day' && !myOut}}" hover-class="none" class="btn vote-open-btn" bindtap="showVoteSheet">🗳 投票放逐{{myDayVote ? '（已投,可改）' : ''}}</button>

    <!-- 主持台：夜晚行动实况 + 白天投票（只有上帝可见,不含开局身份表） -->
    <view class="card host-board" wx:if="{{isHost && status !== 'waiting'}}">
      <view class="sec-title">🎬 主持台（只有你能看到）</view>
      <block wx:if="{{status === 'night' && god && god.night}}">
        <view class="hb-line">🐺 狼人：{{god.night.kill ? '已刀 ' + god.night.kill : (god.night.emptyKill ? '空刀' : '行动中…')}}</view>
        <view class="hb-line">🔮 预言家：{{god.night.seerTarget ? '查验 ' + god.night.seerTarget + ' → ' + (god.night.seerIsWolf ? '狼人 🐺' : '好人 🙂') : (god.night.seerDone ? '（本夜无预言家）' : '行动中…')}}</view>
        <view class="hb-line">🧪 女巫：{{god.night.saved ? '用解药救人 ' : ''}}{{god.night.poison ? '毒了 ' + god.night.poison : ''}}{{(!god.night.saved && !god.night.poison) ? (god.night.witchDone ? '不用药' : '行动中…') : ''}}</view>
        <view class="hb-line hb-dim">解药 {{god.potions.save ? '还在' : '已用'}} · 毒药 {{god.potions.poison ? '还在' : '已用'}}</view>
      </block>
      <block wx:elif="{{status === 'day'}}">
        <view class="hb-line" wx:if="{{god && god.night}}">🌙 昨夜：{{god.night.kill ? '狼人刀了 ' + god.night.kill : '空刀'}}{{god.night.saved ? ' · 女巫用了解药' : ''}}{{god.night.poison ? ' · 女巫毒了 ' + god.night.poison : ''}}</view>
        <view class="hb-line" wx:if="{{god && god.night && god.night.seerTarget}}">🔮 预言家昨夜查验 {{god.night.seerTarget}} → {{god.night.seerIsWolf ? '狼人 🐺' : '好人 🙂'}}</view>
        <view class="hb-line hb-dim" wx:if="{{god && god.potions}}">解药 {{god.potions.save ? '还在' : '已用'}} · 毒药 {{god.potions.poison ? '还在' : '已用'}}</view>
        <view class="hb-line">🗳 白天投票 · 已投 {{dayVoted}} 人（得票见头像角标）</view>
      </block>
    </view>

    <!-- 我的身份卡（玩家）：图腾卡背,长按翻开角色牌 -->
    <view class="card word-card" wx:if="{{status !== 'waiting' && !isHost}}">
      <view class="sec-title">我的身份{{myOut ? '（已出局 👻）' : ''}}</view>
      <view class="idcard {{peeking ? 'open' : ''}}" bindtap="toggleCard">
        <view class="id-inner">
          <!-- 背面(牌背) -->
          <view class="id-face id-back">
            <image wx:if="{{backUrl}}" class="id-img" src="{{backUrl}}" mode="aspectFill"></image>
            <view wx:else class="id-img id-back-css">🐺</view>
          </view>
          <!-- 正面(角色牌) -->
          <view class="id-face id-front">
            <image wx:if="{{roleImg}}" class="id-img" src="{{roleImg}}" mode="aspectFill"></image>
            <view wx:else class="id-img id-front-css">{{roleText}}</view>
            <view class="id-mates" wx:if="{{peeking && matesText}}">狼队友：{{matesText}}</view>
            <view class="id-name" wx:if="{{peeking}}">{{roleText}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 预言家查验记录:常驻,天亮后仍可回看 -->
    <view class="card" wx:if="{{role === 'seer' && status !== 'waiting' && seerLog.length}}">
      <view class="sec-title">🔮 查验记录（只有你能看到）</view>
      <view class="board-line" wx:for="{{seerLog}}" wx:key="round">第 {{item.round}} 夜：{{item.nick}} — <text class="{{item.isWolf ? 'chk-wolf' : 'chk-good'}}">{{item.isWolf ? '狼人 🐺' : '好人 🙂'}}</text></view>
    </view>

    <!-- 上帝：玩家网格（直观看投票票数 / 出局） -->
    <view class="card" wx:if="{{status !== 'waiting' && isHost}}">
      <view class="sec-title">{{status === 'day' ? '🗳 投票情况' : '👥 玩家'}}（{{players.length}}）</view>
      <view class="players game-players">
        <view class="player {{item.out ? 'out' : ''}}" wx:for="{{players}}" wx:key="openid"
          data-openid="{{item.openid}}" data-nick="{{item.nick}}" data-out="{{item.out}}" bindtap="onPlayerTap">
          <view class="host-badge" wx:if="{{item.isHost}}">上帝</view>
          <view class="avatar">
            <image wx:if="{{item.avatar}}" class="avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="pname">{{item.nick}}</view>
          <view class="tomb" wx:if="{{item.out}}">🪦</view>
          <view class="votebadge" wx:if="{{status === 'day' && !item.out && dayTally[item.openid]}}">{{dayTally[item.openid]}}票</view>
        </view>
      </view>
    </view>

    <!-- 夜晚：角色面板 -->
    <block wx:if="{{status === 'night' && !myOut && night}}">
      <!-- 狼人频道 -->
      <view class="card" wx:if="{{role === 'wolf'}}">
        <view class="sec-title">狼人频道 🐺</view>
        <view class="board-line" wx:for="{{night.votes}}" wx:key="nick">{{item.nick}} → {{item.target || '还没选'}}</view>
        <view class="muted night-wait" wx:if="{{night.done}}">刀口已定{{night.kill ? '：' + night.kill : ''}}，等待天亮…</view>
        <block wx:else>
          <button class="btn" bindtap="openKillPick">{{myTargetNick ? '改目标（现选：' + myTargetNick + '）' : '🔪 选择今晚要刀的人'}}</button>
          <button class="btn kill-confirm" wx:if="{{night.wolfCount <= 1 && myTargetNick}}" bindtap="confirmKill">确认刀「{{myTargetNick}}」</button>
          <view class="muted center wolf-hint" wx:if="{{killCountdown > 0}}">双方已选定 · {{killCountdown}} 秒后定刀（改选可重置）</view>
          <view class="muted center wolf-hint" wx:elif="{{night.wolfCount > 1 && myTargetNick}}">已选，等狼队友一起选定</view>
        </block>
      </view>

      <!-- 预言家:夜晚操作提示(记录见下方常驻卡) -->
      <view class="card" wx:if="{{role === 'seer'}}">
        <view class="sec-title">预言家 🔮</view>
        <button class="btn" wx:if="{{!night.done}}" bindtap="openCheckPick">🔮 查验一名玩家（每晚一次）</button>
        <view class="muted night-wait" wx:else>今晚已查验，等待天亮…</view>
      </view>

      <!-- 女巫 -->
      <view class="card" wx:if="{{role === 'witch'}}">
        <view class="sec-title">女巫的药 🧪</view>
        <block wx:if="{{!night.unlocked}}">
          <view class="muted night-wait">狼人还没动手，稍等…</view>
        </block>
        <block wx:elif="{{!night.done}}">
          <view class="board-line">{{night.killId ? '☠️ 今晚「' + night.killNick + '」被刀' : '今晚是空刀，无人被害'}}</view>
          <button class="btn witch-btn" wx:if="{{night.canSave}}" bindtap="witchSave">💊 用解药救 {{night.killNick}}</button>
          <button class="btn btn-ghost witch-btn" wx:if="{{night.canPoison}}" bindtap="openPoisonPick">☠️ 用毒药（选一名玩家）</button>
          <button class="btn btn-ghost witch-btn" bindtap="witchSkip">🌙 不用药</button>
        </block>
        <view class="muted night-wait" wx:else>今晚已行动，等待天亮…</view>
      </view>

      <!-- 平民 -->
      <view class="card" wx:if="{{role === 'villager'}}">
        <view class="muted center night-wait">🌙 夜深了，闭眼睡觉，等待天亮…</view>
      </view>
    </block>

    <!-- 出局的人 -->
    <view class="card" wx:if="{{status !== 'waiting' && status !== 'finished' && myOut}}">
      <view class="muted center night-wait">👻 你已出局，安静吃瓜，等本局结束</view>
    </view>

    <!-- 白天：非房主提示 -->
    <view class="card" wx:if="{{status === 'day' && !isHost && !myOut}}">
      <view class="muted center night-wait">☀️ 回群里发言讨论，口头投票后由房主执行出局</view>
    </view>

    <!-- 已结束：身份公开 -->
    <block wx:if="{{status === 'finished' && reveal}}">
      <view class="card">
        <view class="win-line">{{winnerText}}</view>
        <view class="rev-narr">请亮牌——</view>
        <view class="rev-cards">
          <view class="rev-card {{item.role === 'wolf' ? 'is-wolf' : ''}}"
            wx:for="{{reveal.roles}}" wx:key="openid" style="animation-delay:{{index * 220}}ms">
            <view class="rc-role">{{item.roleName}}</view>
            <view class="rc-nick">{{item.nick}}</view>
          </view>
        </view>
      </view>
      <button wx:if="{{isHost}}" class="btn start-btn" bindtap="playAgain">再来一局</button>
    </block>

    <!-- 房主控制 -->
    <button wx:if="{{isHost && status === 'night'}}" hover-class="none" class="btn dawn-btn" bindtap="wolfDawn">🌅 宣布天亮（结算昨夜）</button>
    <button wx:if="{{isHost && status === 'day'}}" hover-class="none" class="btn dusk-btn" bindtap="wolfDusk">🌙 宣布天黑（按票放逐）</button>

    <button wx:if="{{status !== 'waiting'}}" class="btn btn-ghost start-btn" bindtap="leaveRoom">{{isHost ? '解散房间' : '退出房间'}}</button>
  </block>

  <!-- 夜晚选人弹框(狼刀/验人/毒人共用) -->
  <view class="mask" wx:if="{{showPick}}" bindtap="hidePick">
    <view class="modal" catchtap="">
      <view class="m-title">{{pickTitle}}</view>
      <view class="vt-list">
        <view class="vt-item {{pickMode === 'kill' && item.openid === myTarget ? 'picked' : ''}}"
          wx:for="{{voteTargets}}" wx:key="openid"
          data-openid="{{item.openid}}" data-nick="{{item.nick}}" bindtap="onPick">
          <view class="vt-avatar">
            <image wx:if="{{item.avatar}}" class="vt-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="vt-nick">{{item.nick}}</view>
          <view class="vt-check" wx:if="{{pickMode === 'kill' && item.openid === myTarget}}">✓ 现选</view>
        </view>
      </view>
      <view class="m-btns"><button class="m-cancel" bindtap="hidePick">关闭</button></view>
    </view>
  </view>

  <!-- 白天投票弹框 -->
  <view class="mask" wx:if="{{showVote}}" bindtap="hideVoteSheet">
    <view class="modal" catchtap="">
      <view class="m-title">投出你要放逐的人</view>
      <view class="vt-list">
        <view class="vt-item {{item.openid === myDayVote ? 'picked' : ''}}"
          wx:for="{{voteTargets}}" wx:key="openid"
          data-openid="{{item.openid}}" data-nick="{{item.nick}}" bindtap="voteFor">
          <view class="vt-avatar">
            <image wx:if="{{item.avatar}}" class="vt-img" src="{{item.avatar}}" mode="aspectFill" />
            <block wx:else>{{item.nick[0]}}</block>
          </view>
          <view class="vt-nick">{{item.nick}}</view>
          <view class="vt-check" wx:if="{{item.openid === myDayVote}}">✓ 我投的</view>
        </view>
      </view>
      <view class="m-btns"><button class="m-cancel" bindtap="hideVoteSheet">关闭</button></view>
    </view>
  </view>
</view>

<id-switch />
