/* 狼人杀 —— 复用全局暗夜悬疑风（app.wxss），页面主题色：橙色（对齐 hub 卡片 #ff7a45） */

.btn {
  background: linear-gradient(90deg, #ff7a45, #ffb347);
}
.btn-ghost {
  background: transparent;
}
.btn[disabled] {
  background: linear-gradient(90deg, #ff7a45, #ffb347) !important;
}
.btn-ghost[disabled] {
  background: transparent !important;
}

/* 房间号（对齐 spy 页） */
.code-row { display: flex; align-items: center; justify-content: space-between; }
.code { font-size: 56rpx; font-weight: 700; letter-spacing: 12rpx; color: #fff; margin-top: 8rpx; }
.btn-mini {
  background: rgba(255,122,69,0.3); color: #ffe1d0; font-size: 26rpx;
  padding: 12rpx 28rpx; border-radius: 999rpx; line-height: 1.6;
}
.btn-mini::after { border: none; }
.btn-mini.share { background: linear-gradient(90deg, #ff7a45, #ffb347); color: #fff; }
.code-actions { display: flex; gap: 14rpx; align-items: center; }
.invite-tip { margin-top: 18rpx; }

.row-between { display: flex; align-items: center; justify-content: space-between; }
.sec-title { font-size: 30rpx; font-weight: 600; }

/* 大厅板子说明 */
.board-line { font-size: 26rpx; color: #ddd6ee; margin-top: 14rpx; line-height: 1.6; }

/* 公告条 */
.announce { font-size: 28rpx; font-weight: 600; color: #ffb347; line-height: 1.6; }

/* 玩家网格 */
.players { display: flex; flex-wrap: wrap; justify-content: center; gap: 24rpx; margin-top: 24rpx; }
.player { position: relative; width: 120rpx; text-align: center; }
.avatar {
  width: 96rpx; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  border-radius: 50%; font-size: 40rpx; color: #fff; overflow: hidden;
  background: linear-gradient(135deg, #ff7a45, #ffb347);
}
.avatar .avatar-img { width: 96rpx; height: 96rpx; display: block; }
.pname { font-size: 24rpx; margin-top: 10rpx; color: #ddd6ee; line-height: 1.3; word-break: break-all; }
.host-badge {
  position: absolute; top: -8rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; white-space: nowrap; z-index: 1;
  background: #ffb347; color: #3a2a00; border-radius: 999rpx; padding: 2rpx 10rpx;
}
.ready-badge {
  margin-top: 8rpx; font-size: 18rpx; white-space: nowrap;
  display: inline-block; padding: 2rpx 12rpx; border-radius: 999rpx;
  color: #b3a6cc; background: rgba(255,255,255,0.08);
}
.ready-badge.on { color: #1c3b22; background: #7fe0a8; }
.ready-badge.outtag { color: #fff; background: rgba(255,255,255,0.18); }
.player.out .avatar { opacity: 0.35; filter: grayscale(1); }
.player.out .pname { color: #6f6786; text-decoration: line-through; }
/* 选中态:静态强红光(无入场动画,避免数据刷新时重播闪动) */
.player.picked .avatar { box-shadow: 0 0 0 6rpx #ff4d5e, 0 0 28rpx rgba(255,77,94,0.65); }
.pname-kill { color: #ff6a5c !important; font-weight: 800; }
.knife { position: absolute; top: -14rpx; right: 4rpx; font-size: 36rpx; z-index: 4;
  filter: drop-shadow(0 3rpx 8rpx rgba(0,0,0,0.7)); }
.ready-hint { margin-top: 14rpx; }
.center { text-align: center; }
.warn { color: #ff7a45; }

/* 操作提示 */
.act-tip { margin-top: 14rpx; font-size: 25rpx; color: #ffb347; }

.btn { width: 100% !important; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.start-btn { margin-top: 32rpx; padding: 44rpx 0; font-size: 36rpx; }
.witch-btn { margin-top: 20rpx; font-size: 29rpx; padding: 24rpx 0; }
.night-wait { margin-top: 16rpx; line-height: 1.6; }

/* 加入弹框 */
.mask { position: fixed; inset: 0; z-index: 30; display: flex; align-items: center; justify-content: center;
  background: rgba(10,6,20,0.75); }
.modal { width: 78%; padding: 44rpx 36rpx; border-radius: 24rpx;
  background: #2a2140; border: 1rpx solid rgba(255,255,255,0.12); }
.m-title { font-size: 34rpx; font-weight: 700; color: #ece8f5; text-align: center; }
.m-input { margin: 30rpx auto 0; height: 96rpx; border-radius: 16rpx; font-size: 40rpx; letter-spacing: 12rpx;
  text-align: center; color: #fff; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.16); }
.m-tip { margin-top: 16rpx; text-align: center; font-size: 24rpx; color: #b3a6cc; }
.m-btns { margin-top: 26rpx; display: flex; gap: 20rpx; }
.m-cancel { flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center; margin: 0;
  border-radius: 16rpx; font-size: 29rpx; font-weight: 600;
  color: #d9d2ec; background: transparent; border: 1rpx solid rgba(255,255,255,0.25); }
.m-cancel::after { border: none; }

/* 身份卡 */
.word-card { text-align: center; }
.word-card .sec-title { text-align: left; }
.wc-body { position: relative; margin-top: 22rpx; min-height: 120rpx; }
.wc-word { font-size: 64rpx; font-weight: 700; color: #fff; letter-spacing: 4rpx; line-height: 110rpx;
  text-shadow: 0 4rpx 20rpx rgba(255,122,69,0.45); }
.mates { font-size: 27rpx; color: #ffb347; margin-top: 4rpx; padding-bottom: 12rpx; }
.wc-cover { padding: 34rpx 0; border-radius: 16rpx; font-size: 26rpx; color: #b3a6cc;
  background: rgba(0,0,0,0.25); border: 1rpx dashed rgba(255,255,255,0.2); }
.wc-cover.ghost { position: absolute; inset: 0; z-index: 5; opacity: 0; padding: 0; border: none; }

/* 揭晓 */
.win-line { font-size: 36rpx; font-weight: 700; color: #ffb347; text-align: center; margin-bottom: 14rpx; }
.rev-row { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; }
.rev-v { font-size: 30rpx; font-weight: 700; color: #fff; }

/* 未结束对局的回去横幅（大厅顶部） */
.resume-bar {
  display: flex; align-items: center; margin: 0 0 20rpx; padding: 20rpx 26rpx;
  border-radius: 20rpx; font-size: 26rpx; color: #ffe3a0;
  background: rgba(255,206,84,0.1); border: 1rpx solid rgba(255,206,84,0.32);
}
.rb-go { margin-left: auto; font-weight: 700; color: #ffce54; }



/* ── 身份卡：图腾卡背,长按翻开木刻角色牌 ── */
.idcard { position: relative; width: 340rpx; height: 480rpx; margin: 20rpx auto 6rpx;
  perspective: 1400rpx; }
/* 内层随点击绕 Y 轴翻 180° */
.id-inner { position: absolute; inset: 0; transform-style: preserve-3d;
  transition: transform 0.5s cubic-bezier(0.4, 0.1, 0.3, 1); }
.idcard.open .id-inner { transform: rotateY(180deg); }
.id-face { position: absolute; left: 0; top: 0; width: 100%; height: 100%; border-radius: 20rpx; overflow: hidden;
  backface-visibility: hidden; -webkit-backface-visibility: hidden;
  box-shadow: 0 16rpx 44rpx rgba(0,0,0,0.5); }
.id-back { transform: rotateY(0deg); }
.id-front { transform: rotateY(180deg); }

.id-img { width: 100%; height: 100%; border-radius: 20rpx; }
.id-back-css { display: flex; align-items: center; justify-content: center; font-size: 100rpx;
  background: linear-gradient(160deg, #3a2a20, #241812); }
.id-front-css { display: flex; align-items: center; justify-content: center; font-size: 44rpx; font-weight: 900;
  color: #fff; background: linear-gradient(160deg, #2c2244, #221936); }
.id-name { position: absolute; left: 0; right: 0; bottom: 14rpx; text-align: center;
  font-size: 30rpx; font-weight: 900; letter-spacing: 4rpx; color: #ffe8c9;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.9); }
.id-hint { position: absolute; left: 0; right: 0; bottom: 10rpx; text-align: center;
  font-size: 17rpx; letter-spacing: 2rpx; color: rgba(255,255,255,0.75);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.9); }
.word-card .mates { text-align: center; margin-top: 12rpx; }

/* 一次性上传按钮（跑完删除） */
.dev-upload { margin: 40rpx auto 0; width: 80%; font-size: 26rpx; color: #fff;
  background: rgba(255,255,255,0.14); border: 1rpx solid rgba(255,255,255,0.3); border-radius: 999rpx; }

/* ── 墓碑:出局头顶弹出 ── */
.tomb { position: absolute; top: -20rpx; left: 50%; margin-left: -18rpx; font-size: 36rpx; z-index: 3;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.6));
  animation: tombpop 0.5s cubic-bezier(0.2, 1.8, 0.4, 1); }
@keyframes tombpop { 0% { transform: translateY(16rpx) scale(0); opacity: 0; } 100% { transform: none; opacity: 1; } }

/* ── 终局:依次亮牌,狼人牌深红 ── */
.rev-narr { text-align: center; font-size: 24rpx; letter-spacing: 6rpx; color: #b3a6cc; margin: 8rpx 0 18rpx; }
.rev-cards { display: flex; flex-wrap: wrap; justify-content: center; gap: 14rpx; }
.rev-card { width: 128rpx; height: 176rpx; border-radius: 14rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  background: linear-gradient(165deg, #efe3c8, #d9c9a3); border: 3rpx solid #8a7450;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.4);
  transform: rotateY(90deg); opacity: 0; animation: flipin 0.45s ease forwards; }
@keyframes flipin { 0% { transform: rotateY(90deg); opacity: 0; } 100% { transform: none; opacity: 1; } }
.rev-card .rc-role { font-size: 26rpx; font-weight: 900; letter-spacing: 2rpx; color: #3a3020; }
.rev-card .rc-nick { font-size: 19rpx; color: #6b5c3a; max-width: 112rpx; overflow: hidden;
  white-space: nowrap; text-overflow: ellipsis; }
.rev-card.is-wolf { background: linear-gradient(165deg, #7a1f2e, #4a1220); border-color: #a8324e; }
.rev-card.is-wolf .rc-role { color: #ffd9c9; }
.rev-card.is-wolf .rc-nick { color: #d9909e; }

/* ── 昼夜森林底图:双层交叉淡入(1s),天亮=同一片森林的清晨 ── */
.scene-bg { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0;
  opacity: 0; transition: opacity 1s ease; pointer-events: none; }
.scene-bg.on { opacity: 0.42; }
.scene-bg.bg-day.on { opacity: 0.3; }   /* 晨光图更亮,压低一点保 UI */
.scene-fade { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none;
  background: linear-gradient(180deg, rgba(30,24,48,0.15) 0%, rgba(30,24,48,0.55) 45%, rgba(30,24,48,0.8) 100%); }
.title, .subtitle, .resume-bar, .card, .btn, .ready-hint, .center, .dev-upload { position: relative; z-index: 1; }

/* ── 阶段卡:白天/黑夜大字 + 行动说明 ── */
.phase-card { text-align: center; border-color: rgba(139,92,255,0.35); }
.phase-card.p-day { border-color: rgba(255,180,80,0.4); }
.ph-big { font-size: 34rpx; font-weight: 900; letter-spacing: 3rpx; color: #fff; }
.phase-card.p-day .ph-big { color: #ffd9a8; }
.ph-sub { font-size: 23rpx; color: #b3a6cc; margin-top: 12rpx; line-height: 1.7; }
.ph-sub2 { font-size: 21rpx; color: #8d81a8; margin-top: 6rpx; }
.share-btn { background: linear-gradient(90deg, #ff9a45, #ffce54); color: #3a2408; }
.room-code-line { margin-top: 14rpx; font-size: 22rpx; }
.id-mates { position: absolute; left: 0; right: 0; bottom: 66rpx; text-align: center;
  font-size: 22rpx; color: #ffd9c9; text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.9); }
.kill-confirm { margin-top: 18rpx; background: linear-gradient(90deg, #a8324e, #d43a52); }
.wolf-hint { margin-top: 14rpx; font-size: 22rpx; }

/* ══ 等待房间：布局对齐剧本杀 ══ */
.rm-script { text-align: center; font-size: 44rpx; font-weight: 700; color: #fff; margin-top: 12rpx; letter-spacing: 4rpx; position: relative; }
.codebox { text-align: center; margin: 34rpx 0 4rpx; position: relative; }
.code-lab { font-size: 22rpx; letter-spacing: 10rpx; color: #8a7fa6; }
.code-big {
  font-size: 140rpx; font-weight: 900; letter-spacing: 30rpx; color: #fff; line-height: 1.35;
  text-shadow: 0 0 50rpx rgba(140, 100, 255, 0.45);
}
.rm-narr { text-align: center; font-size: 25rpx; color: #b3a6cc; margin-bottom: 26rpx; position: relative; }

.rm-players { display: flex; flex-wrap: wrap; justify-content: center; gap: 28rpx 30rpx; margin: 8rpx 0 4rpx; position: relative; }
.rm-players .avatar { position: relative; overflow: visible; }
.rm-players .avatar .avatar-img { border-radius: 50%; }
.okmark {
  position: absolute; right: -6rpx; top: -6rpx; z-index: 2;
  width: 36rpx; height: 36rpx; line-height: 36rpx; text-align: center;
  border-radius: 50%; font-size: 22rpx; font-weight: 700; color: #c2451e;
  background: #fff6ea;
  border: 2rpx solid #1e1830;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.45);
}
.avatar.slot-empty {
  background: none; border: 2rpx dashed rgba(255, 255, 255, 0.25);
  color: #8a7fa6; font-size: 34rpx; box-sizing: border-box;
}
.pname-dim { color: #8a7fa6; }
.rm-count { margin-top: 20rpx; position: relative; }

/* ── 游戏中卡片:实底,不透背景(对齐海龟汤风格) ── */
.card { background: #2c2447; border: 1rpx solid rgba(255,255,255,0.16);
  box-shadow: 0 12rpx 34rpx rgba(0,0,0,0.35); }
.phase-card { background: #322a52; }           /* 阶段卡稍亮一档,做主角 */
.phase-card.p-day { background: #43324a; }      /* 白天暖调实底 */
.btn-ghost { background: #2a2342; }

.chk-wolf { color: #ff8f8f; font-weight: 700; }
.chk-good { color: #b9e6a8; font-weight: 700; }

/* 白天投票:得票角标 + 我投的高亮 */
.votebadge { position: absolute; top: -12rpx; right: -4rpx; font-size: 18rpx; font-weight: 800; color: #fff;
  background: #c44dff; border-radius: 999rpx; padding: 2rpx 10rpx; z-index: 4; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.5); }
.pname-vote { color: #d9b8ff !important; font-weight: 800; }
.player.picked .avatar, .player.voted .avatar { /* 占位,兼容 */ }
.dawn-btn { background: linear-gradient(90deg, #ff9a45, #ffce54); color: #3a2408; }
.dusk-btn { background: linear-gradient(90deg, #5a4bff, #8b5cff); color: #fff; }

.mini-btn { align-self: flex-start; line-height: 1.7;
  background: rgba(123,92,255,0.3); color: #ddd2ff;
  font-size: 22rpx; padding: 6rpx 20rpx; border-radius: 999rpx; }
.ph-copy { display: inline-block; margin-top: 14rpx; white-space: nowrap; }
.ph-script { text-align: left; white-space: pre-line; font-size: 24rpx; line-height: 1.9;
  color: #d6cef0; margin-top: 16rpx; }

/* ── 主持台:夜晚行动实况(不含身份表) ── */
.host-board { background: #2a2340; border-color: rgba(255,206,84,0.3); }
.hb-line { font-size: 25rpx; color: #ddd6ee; line-height: 1.9; margin-top: 6rpx; }
.hb-dim { font-size: 21rpx; color: #9d8fbe; }
.hb-script { white-space: pre-line; font-size: 24rpx; line-height: 1.9; color: #d6cef0;
  margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx dashed rgba(255,255,255,0.12); }

/* ── 白天投票弹框(对齐卧底) ── */
.vt-list { margin-top: 26rpx; display: flex; flex-direction: column; gap: 16rpx; max-height: 56vh; overflow-y: auto; }
.vt-item { display: flex; align-items: center; gap: 20rpx; padding: 18rpx 22rpx; border-radius: 18rpx;
  background: rgba(255,255,255,0.05); border: 2rpx solid rgba(255,255,255,0.12); }
.vt-item.picked { border-color: #8b5cff; background: rgba(139,92,255,0.16); }
.vt-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; overflow: hidden; display: flex;
  align-items: center; justify-content: center; font-size: 30rpx; color: #fff;
  background: linear-gradient(135deg, #7b5cff, #c44dff); }
.vt-img { width: 72rpx; height: 72rpx; display: block; }
.vt-nick { flex: 1; font-size: 30rpx; font-weight: 600; color: #ece8f5; }
.vt-check { font-size: 24rpx; color: #c9a4ff; font-weight: 600; }
.game-players { margin-top: 20rpx; }
.game-tip { margin-top: 20rpx; text-align: center; }

/* 主持台标题行 + 记录按钮 */
.hb-head { display: flex; justify-content: space-between; align-items: center; }
.log-btn { font-size: 22rpx; color: #ddd2ff; background: rgba(123,92,255,0.3);
  padding: 6rpx 20rpx; border-radius: 999rpx; }
/* 对局记录弹框 */
.log-list { max-height: 60vh; margin-top: 20rpx; }
.log-empty { text-align: center; color: #9d8fbe; font-size: 24rpx; padding: 40rpx 0; }
.log-item { border-left: 4rpx solid rgba(255,255,255,0.15); padding: 8rpx 0 12rpx 20rpx; margin-bottom: 16rpx; }
.log-item.night { border-left-color: #7b5cff; }
.log-item.day { border-left-color: #ffce54; }
.log-round { font-size: 24rpx; font-weight: 800; color: #fff; margin-bottom: 6rpx; }
.log-line { font-size: 23rpx; color: #ddd6ee; line-height: 1.8; }
.log-dead { color: #ff9db4; }
.copy-report-btn { background: linear-gradient(90deg, #7b5cff, #c44dff); color: #fff; }

/* 大厅顶部立绘（与卧底大厅一致） */
.lobby-hero { display: block; width: 300rpx; height: 300rpx; margin: 0 auto -10rpx;
  position: relative; z-index: 1;
  filter: drop-shadow(0 14rpx 30rpx rgba(0,0,0,0.5)); }

/* 次要操作（解散/退出）：矮一档 */
.btn-slim { padding: 22rpx 0; font-size: 30rpx; }

/* 终局卡内的复制战报：文字超链接样式 */
.copy-link {
  margin-top: 24rpx; text-align: center;
  font-size: 27rpx; color: #ffb347; text-decoration: underline;
  text-underline-offset: 6rpx;
}
.copy-link:active { opacity: 0.7; }
/* 终局阶段卡只剩复制链接时：去掉上边距，卡片显得紧凑 */
.copy-link-lone { margin-top: 0; }
