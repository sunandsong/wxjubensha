/* 狼人杀 —— 复用全局暗夜悬疑风（app.wxss），页面主题色：橙色（对齐 hub 卡片 #ff7a45） */

.btn {
  background: linear-gradient(90deg, #ff7a45, #ffb347);
}
.btn-ghost {
  background: transparent;
}
.btn[disabled] {
  background: linear-gradient(90deg, #ff7a45, #ffb347) !important;
}
.btn-ghost[disabled] {
  background: transparent !important;
}

/* 房间号（对齐 spy 页） */
.code-row { display: flex; align-items: center; justify-content: space-between; }
.code { font-size: 56rpx; font-weight: 700; letter-spacing: 12rpx; color: #fff; margin-top: 8rpx; }
.btn-mini {
  background: rgba(255,122,69,0.3); color: #ffe1d0; font-size: 26rpx;
  padding: 12rpx 28rpx; border-radius: 999rpx; line-height: 1.6;
}
.btn-mini::after { border: none; }
.btn-mini.share { background: linear-gradient(90deg, #ff7a45, #ffb347); color: #fff; }
.code-actions { display: flex; gap: 14rpx; align-items: center; }
.invite-tip { margin-top: 18rpx; }

.row-between { display: flex; align-items: center; justify-content: space-between; }
.sec-title { font-size: 30rpx; font-weight: 600; }

/* 大厅板子说明 */
.board-line { font-size: 26rpx; color: #ddd6ee; margin-top: 14rpx; line-height: 1.6; }

/* 公告条 */
.announce { font-size: 28rpx; font-weight: 600; color: #ffb347; line-height: 1.6; }

/* 玩家网格 */
.players { display: flex; flex-wrap: wrap; justify-content: center; gap: 24rpx; margin-top: 24rpx; }
.player { position: relative; width: 120rpx; text-align: center; }
.avatar {
  width: 96rpx; height: 96rpx; line-height: 96rpx; margin: 0 auto;
  border-radius: 50%; font-size: 40rpx; color: #fff; overflow: hidden;
  background: linear-gradient(135deg, #ff7a45, #ffb347);
}
.avatar .avatar-img { width: 96rpx; height: 96rpx; display: block; }
.pname { font-size: 24rpx; margin-top: 10rpx; color: #ddd6ee; line-height: 1.3; word-break: break-all; }
.host-badge {
  position: absolute; top: -8rpx; left: 50%; transform: translateX(-50%);
  font-size: 18rpx; white-space: nowrap; z-index: 1;
  background: #ffb347; color: #3a2a00; border-radius: 999rpx; padding: 2rpx 10rpx;
}
.ready-badge {
  margin-top: 8rpx; font-size: 18rpx; white-space: nowrap;
  display: inline-block; padding: 2rpx 12rpx; border-radius: 999rpx;
  color: #b3a6cc; background: rgba(255,255,255,0.08);
}
.ready-badge.on { color: #1c3b22; background: #7fe0a8; }
.ready-badge.outtag { color: #fff; background: rgba(255,255,255,0.18); }
.player.out .avatar { opacity: 0.35; filter: grayscale(1); }
.player.out .pname { color: #6f6786; text-decoration: line-through; }
.player.picked .avatar { box-shadow: 0 0 0 5rpx #ffb347; }
.ready-hint { margin-top: 14rpx; }
.center { text-align: center; }
.warn { color: #ff7a45; }

/* 操作提示 */
.act-tip { margin-top: 14rpx; font-size: 25rpx; color: #ffb347; }

.btn { width: 100% !important; box-sizing: border-box; margin-left: 0; margin-right: 0; }
.start-btn { margin-top: 32rpx; }
.witch-btn { margin-top: 20rpx; font-size: 29rpx; padding: 24rpx 0; }
.night-wait { margin-top: 16rpx; line-height: 1.6; }

/* 加入弹框 */
.mask { position: fixed; inset: 0; z-index: 30; display: flex; align-items: center; justify-content: center;
  background: rgba(10,6,20,0.75); }
.modal { width: 78%; padding: 44rpx 36rpx; border-radius: 24rpx;
  background: #2a2140; border: 1rpx solid rgba(255,255,255,0.12); }
.m-title { font-size: 34rpx; font-weight: 700; color: #ece8f5; text-align: center; }
.m-input { margin: 30rpx auto 0; height: 96rpx; border-radius: 16rpx; font-size: 40rpx; letter-spacing: 12rpx;
  text-align: center; color: #fff; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.16); }
.m-tip { margin-top: 16rpx; text-align: center; font-size: 24rpx; color: #b3a6cc; }
.m-btns { margin-top: 26rpx; display: flex; gap: 20rpx; }
.m-cancel { flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center; margin: 0;
  border-radius: 16rpx; font-size: 29rpx; font-weight: 600;
  color: #d9d2ec; background: transparent; border: 1rpx solid rgba(255,255,255,0.25); }
.m-cancel::after { border: none; }

/* 身份卡 */
.word-card { text-align: center; }
.word-card .sec-title { text-align: left; }
.wc-body { position: relative; margin-top: 22rpx; min-height: 120rpx; }
.wc-word { font-size: 64rpx; font-weight: 700; color: #fff; letter-spacing: 4rpx; line-height: 110rpx;
  text-shadow: 0 4rpx 20rpx rgba(255,122,69,0.45); }
.mates { font-size: 27rpx; color: #ffb347; margin-top: 4rpx; padding-bottom: 12rpx; }
.wc-cover { padding: 34rpx 0; border-radius: 16rpx; font-size: 26rpx; color: #b3a6cc;
  background: rgba(0,0,0,0.25); border: 1rpx dashed rgba(255,255,255,0.2); }
.wc-cover.ghost { position: absolute; inset: 0; z-index: 5; opacity: 0; padding: 0; border: none; }

/* 揭晓 */
.win-line { font-size: 36rpx; font-weight: 700; color: #ffb347; text-align: center; margin-bottom: 14rpx; }
.rev-row { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; }
.rev-v { font-size: 30rpx; font-weight: 700; color: #fff; }

/* 未结束对局的回去横幅（大厅顶部） */
.resume-bar {
  display: flex; align-items: center; margin: 0 0 20rpx; padding: 20rpx 26rpx;
  border-radius: 20rpx; font-size: 26rpx; color: #ffe3a0;
  background: rgba(255,206,84,0.1); border: 1rpx solid rgba(255,206,84,0.32);
}
.rb-go { margin-left: auto; font-weight: 700; color: #ffce54; }

/* ── 上帝视角面板 ── */
.god-card { border-color: rgba(255,206,84,0.35); }
.god-row { display: flex; justify-content: space-between; align-items: center;
  padding: 12rpx 4rpx; border-bottom: 1rpx dashed rgba(255,255,255,0.1); font-size: 26rpx; }
.g-nick.gout { text-decoration: line-through; opacity: 0.5; }
.g-role { font-weight: 700; }
.g-role.wolf { color: #ff8f8f; }
.g-role.seer { color: #8fd0ff; }
.g-role.witch { color: #c9a4ff; }
.g-role.villager { color: #b9e6a8; }
.god-night { margin-top: 14rpx; font-size: 22rpx; color: #b3a6cc; line-height: 1.7; }

/* ── 身份卡：图腾卡背,长按翻开木刻角色牌 ── */
.idcard { position: relative; width: 340rpx; height: 480rpx; margin: 20rpx auto 6rpx;
  border-radius: 20rpx; overflow: hidden; perspective: 1000rpx;
  box-shadow: 0 16rpx 44rpx rgba(0,0,0,0.5); }
.id-face { position: absolute; left: 0; top: 0; width: 100%; height: 100%;
  transition: opacity 0.35s ease, transform 0.35s ease; border-radius: 20rpx; }
.id-back { opacity: 1; transform: none; }
.id-front { opacity: 0; transform: scale(1.06); }
.idcard.open .id-back { opacity: 0; transform: scale(0.96); }
.idcard.open .id-front { opacity: 1; transform: none; }
.id-back-css { display: flex; align-items: center; justify-content: center; font-size: 100rpx;
  background: linear-gradient(160deg, #3a2a20, #241812); }
.id-front-css { display: flex; align-items: center; justify-content: center; font-size: 44rpx; font-weight: 900;
  color: #fff; background: linear-gradient(160deg, #2c2244, #221936); }
.id-name { position: absolute; left: 0; right: 0; bottom: 14rpx; text-align: center;
  font-size: 30rpx; font-weight: 900; letter-spacing: 4rpx; color: #ffe8c9;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.9); }
.id-hint { position: absolute; left: 0; right: 0; bottom: 14rpx; text-align: center;
  font-size: 20rpx; letter-spacing: 2rpx; color: rgba(255,255,255,0.75);
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.9); }
.word-card .mates { text-align: center; margin-top: 12rpx; }

/* 一次性上传按钮（跑完删除） */
.dev-upload { margin: 40rpx auto 0; width: 80%; font-size: 26rpx; color: #fff;
  background: rgba(255,255,255,0.14); border: 1rpx solid rgba(255,255,255,0.3); border-radius: 999rpx; }

/* ── 米勒山谷:满月村庄剪影横幅(CSS 版,夜/昼/终局三态) ── */
.village { position: relative; height: 220rpx; margin: 0 -28rpx 4rpx; overflow: hidden;
  background: linear-gradient(180deg, #100c22 0%, #241b3e 70%, rgba(30,24,48,0) 100%);
  transition: background 0.8s; }
.v-orb { position: absolute; right: 90rpx; top: 30rpx; width: 72rpx; height: 72rpx; border-radius: 50%;
  background: radial-gradient(circle at 38% 35%, #fff, #e8e4f8 55%, #b8aede);
  box-shadow: 0 0 34rpx rgba(210,200,255,0.55); transition: all 0.8s; }
.v-sil { position: absolute; bottom: 34rpx; background: #0d0a18; transition: background 0.8s; }
.v-sil.church { left: 90rpx; width: 90rpx; height: 80rpx; }
.v-sil.spire { left: 112rpx; width: 46rpx; height: 130rpx;
  clip-path: polygon(50% 0, 100% 38%, 100% 100%, 0 100%, 0 38%); }
.v-sil.hut1 { left: 220rpx; width: 84rpx; height: 56rpx; clip-path: polygon(50% 0, 100% 34%, 100% 100%, 0 100%, 0 34%); }
.v-sil.hut2 { left: 330rpx; width: 70rpx; height: 46rpx; clip-path: polygon(50% 0, 100% 36%, 100% 100%, 0 100%, 0 36%); }
.v-sil.pine1 { right: 200rpx; width: 44rpx; height: 90rpx; clip-path: polygon(50% 0, 88% 55%, 70% 55%, 100% 100%, 0 100%, 30% 55%, 12% 55%); }
.v-sil.pine2 { right: 150rpx; width: 34rpx; height: 66rpx; clip-path: polygon(50% 0, 88% 55%, 70% 55%, 100% 100%, 0 100%, 30% 55%, 12% 55%); }
.v-sil.pine3 { right: 40rpx; width: 40rpx; height: 78rpx; clip-path: polygon(50% 0, 88% 55%, 70% 55%, 100% 100%, 0 100%, 30% 55%, 12% 55%); }
/* 教堂的小窗:夜里一点灯火呼吸 */
.v-win { position: absolute; left: 128rpx; bottom: 66rpx; width: 10rpx; height: 16rpx;
  border-radius: 5rpx 5rpx 0 0; background: #ffb85c; box-shadow: 0 0 12rpx rgba(255,170,80,0.9);
  animation: winbreath 3s ease-in-out infinite; }
@keyframes winbreath { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
.v-phase { position: absolute; left: 0; right: 0; bottom: 0; text-align: center;
  font-size: 22rpx; letter-spacing: 3rpx; color: #b3a6cc; }
/* 白天:暖光洒在同一座村庄 */
.village.vday { background: linear-gradient(180deg, #4a3050 0%, #6e4a45 60%, rgba(30,24,48,0) 100%); }
.village.vday .v-orb { background: radial-gradient(circle at 38% 35%, #fff8e0, #ffd98a 60%, #ff9a45);
  box-shadow: 0 0 44rpx rgba(255,180,80,0.7); }
.village.vday .v-sil { background: #241626; }
.village.vday .v-win { opacity: 0; animation: none; }
.village.vday .v-phase { color: #ffd9a8; }
/* 终局:暮色 */
.village.vdusk { background: linear-gradient(180deg, #241626 0%, #3d2038 60%, rgba(30,24,48,0) 100%); }
.village.vdusk .v-phase { color: #ff9db4; }

/* ── 墓碑:出局头顶弹出 ── */
.tomb { position: absolute; top: -20rpx; left: 50%; margin-left: -18rpx; font-size: 36rpx; z-index: 3;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.6));
  animation: tombpop 0.5s cubic-bezier(0.2, 1.8, 0.4, 1); }
@keyframes tombpop { 0% { transform: translateY(16rpx) scale(0); opacity: 0; } 100% { transform: none; opacity: 1; } }

/* ── 终局:依次亮牌,狼人牌深红 ── */
.rev-narr { text-align: center; font-size: 24rpx; letter-spacing: 6rpx; color: #b3a6cc; margin: 8rpx 0 18rpx; }
.rev-cards { display: flex; flex-wrap: wrap; justify-content: center; gap: 14rpx; }
.rev-card { width: 128rpx; height: 176rpx; border-radius: 14rpx; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  background: linear-gradient(165deg, #efe3c8, #d9c9a3); border: 3rpx solid #8a7450;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.4);
  transform: rotateY(90deg); opacity: 0; animation: flipin 0.45s ease forwards; }
@keyframes flipin { 0% { transform: rotateY(90deg); opacity: 0; } 100% { transform: none; opacity: 1; } }
.rev-card .rc-role { font-size: 26rpx; font-weight: 900; letter-spacing: 2rpx; color: #3a3020; }
.rev-card .rc-nick { font-size: 19rpx; color: #6b5c3a; max-width: 112rpx; overflow: hidden;
  white-space: nowrap; text-overflow: ellipsis; }
.rev-card.is-wolf { background: linear-gradient(165deg, #7a1f2e, #4a1220); border-color: #a8324e; }
.rev-card.is-wolf .rc-role { color: #ffd9c9; }
.rev-card.is-wolf .rc-nick { color: #d9909e; }

/* ── 昼夜森林底图:双层交叉淡入(1s),天亮=同一片森林的清晨 ── */
.scene-bg { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0;
  opacity: 0; transition: opacity 1s ease; pointer-events: none; }
.scene-bg.on { opacity: 0.42; }
.scene-bg.bg-day.on { opacity: 0.3; }   /* 晨光图更亮,压低一点保 UI */
.scene-fade { position: fixed; left: 0; top: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none;
  background: linear-gradient(180deg, rgba(30,24,48,0.15) 0%, rgba(30,24,48,0.55) 45%, rgba(30,24,48,0.8) 100%); }
.title, .subtitle, .resume-bar, .card, .btn, .village, .ready-hint, .center, .dev-upload { position: relative; z-index: 1; }
